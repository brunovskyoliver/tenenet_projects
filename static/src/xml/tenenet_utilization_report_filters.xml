<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="tenenet_projects.TenenetUtilizationReportFilters" t-inherit="account_reports.AccountReportFiltersCustomizable">
        <xpath expr="//div[@id='filter_date']/t[@t-call='account_reports.AccountReportFilterDate']" position="replace">
            <t t-call="tenenet_projects.TenenetUtilizationReportFilterDate"/>
        </xpath>
        <xpath expr="//div[@id='filter_variant']" position="replace"/>
        <xpath expr="//div[@id='filter_date']" position="after">
            <div id="filter_tenenet_warnings">
                <button
                    class="btn btn-secondary"
                    t-att-class="{ active: filterWarnings }"
                    t-on-click="() => this.toggleFilterWarnings()"
                >
                    <i class="fa fa-exclamation-triangle me-1"/>Len varovania
                </button>
            </div>
        </xpath>
    </t>

    <t t-name="tenenet_projects.TenenetUtilizationReportFilterDate" owl="1">
        <Dropdown menuClass="'account_report_filter date'" navigationOptions="dateNavigationOptions">
            <button class="btn btn-secondary">
                <i class="fa fa-calendar me-1"/>
                <t t-out="monthFilterLabel"/>
            </button>

            <t t-set-slot="content">
                <DropdownItem
                    tag="'div'"
                    class="{ 'd-flex justify-content-between date_filter date_filter_month selected': true }"
                    attrs="{ 'data-period-type': 'month', 'data-mode': 'edit' }"
                    onSelected="() => this.selectMonthPeriod()"
                    closingMode="'none'"
                >
                    <div class="filter_name pe-3">
                        Mesiac
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <button
                            class="btn_previous_date fa fa-caret-left"
                            t-on-click="() => this.selectPreviousPeriod('month')"
                        />
                        <DateTimeInput
                            type="'date'"
                            class="'o-navigable text-center border-0 bg-transparent'"
                            value="selectedMonthValue"
                            format="'MMM yyyy'"
                            minPrecision="'months'"
                            maxPrecision="'months'"
                            showWeekNumbers="false"
                            onChange="(date) => this.selectMonth(date)"
                        />
                        <button
                            class="btn_next_date fa fa-caret-right"
                            t-on-click="() => this.selectNextPeriod('month')"
                        />
                    </div>
                </DropdownItem>
            </t>
        </Dropdown>
    </t>
</templates>
