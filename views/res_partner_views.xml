<odoo>
    <data>
        <record id="view_res_partner_form_tenenet" model="ir.ui.view">
            <field name="name">res.partner.form.tenenet</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet//group[1]" position="inside">
                    <group string="TENENET">
                        <field name="is_tenenet_client"/>
                        <field name="is_tenenet_partner"/>
                        <field name="is_tenenet_landlord"/>
                        <field name="is_tenenet_employee_contact" readonly="1"/>
                        <field name="tenenet_contact_role_summary" readonly="1"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="view_res_partner_tenenet_list" model="ir.ui.view">
            <field name="name">res.partner.tenenet.list</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list string="TENENET kontakty">
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="is_tenenet_client"/>
                    <field name="is_tenenet_partner"/>
                    <field name="is_tenenet_landlord"/>
                    <field name="is_tenenet_employee_contact" optional="hide"/>
                    <field name="tenenet_contact_role_summary"/>
                </list>
            </field>
        </record>

        <record id="view_res_partner_tenenet_search" model="ir.ui.view">
            <field name="name">res.partner.tenenet.search</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <filter string="Klienti" name="tenenet_clients" domain="[('is_tenenet_client', '=', True)]"/>
                    <filter string="Partneri" name="tenenet_partners" domain="[('is_tenenet_partner', '=', True)]"/>
                    <filter string="Prenajímatelia" name="tenenet_landlords" domain="[('is_tenenet_landlord', '=', True)]"/>
                    <filter string="Klienti a partneri" name="tenenet_clients_or_partners" domain="['|', ('is_tenenet_client', '=', True), ('is_tenenet_partner', '=', True)]"/>
                </xpath>
            </field>
        </record>

        <record id="action_tenenet_clients" model="ir.actions.act_window">
            <field name="name">Klienti</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_res_partner_tenenet_list"/>
            <field name="search_view_id" ref="view_res_partner_tenenet_search"/>
            <field name="domain">[('is_tenenet_client', '=', True)]</field>
        </record>

        <record id="action_tenenet_partners" model="ir.actions.act_window">
            <field name="name">Partneri</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_res_partner_tenenet_list"/>
            <field name="search_view_id" ref="view_res_partner_tenenet_search"/>
            <field name="domain">[('is_tenenet_partner', '=', True)]</field>
        </record>
    </data>
</odoo>
