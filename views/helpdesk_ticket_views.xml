<odoo>
    <data>
        <record id="view_tenenet_helpdesk_subtask_form" model="ir.ui.view">
            <field name="name">tenenet.helpdesk.subtask.form</field>
            <field name="model">tenenet.helpdesk.subtask</field>
            <field name="arch" type="xml">
                <form string="Čiastková úloha">
                    <header>
                        <field
                            name="is_done"
                            widget="tenenet_subtask_done_checkmark"
                            class="oe_inline"
                        />
                    </header>
                    <sheet>
                        <group>
                            <field name="ticket_id" readonly="1"/>
                            <field name="company_id" invisible="1"/>
                            <field name="show_seen_display" invisible="1"/>
                            <field name="show_seen_button" invisible="1"/>
                            <field name="can_view_seen_info" invisible="1"/>
                            <field name="name"/>
                            <field name="priority" widget="priority"/>
                            <field
                                name="employee_ids"
                                widget="many2many_avatar_employee"
                                context="{'active_test': True}"
                                domain="['|', ('company_id', '=', False), ('company_id', '=', company_id)]"
                            />
                            <field name="date_deadline"/>
                            <field
                                name="single_seen_display"
                                string="Videné"
                                readonly="1"
                                invisible="not show_seen_display"
                            />
                        </group>
                        <field
                            name="seen_detail_html"
                            string="Videné"
                            widget="html"
                            readonly="1"
                            nolabel="1"
                            invisible="not can_view_seen_info"
                        />
                        <notebook>
                            <page name="description" string="Popis">
                                <field name="description" type="html" options="{'collaborative': true, 'resizable': false}"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_tenenet_helpdesk_subtask_seen_wizard_form" model="ir.ui.view">
            <field name="name">tenenet.helpdesk.subtask.seen.wizard.form</field>
            <field name="model">tenenet.helpdesk.subtask.seen.wizard</field>
            <field name="arch" type="xml">
                <form string="Kto videl">
                    <sheet>
                        <group>
                            <field name="subtask_id" readonly="1"/>
                        </group>
                        <field name="line_ids" nolabel="1" readonly="1">
                            <list create="0" edit="0" delete="0" decoration-success="has_seen" decoration-muted="not has_user">
                                <field name="employee_id" widget="many2one_avatar_employee"/>
                                <field name="user_id" widget="many2one_avatar_user"/>
                                <field name="has_seen" string="Videl" widget="boolean"/>
                                <field name="seen_at" string="Čas videnia"/>
                            </list>
                        </field>
                    </sheet>
                    <footer>
                        <button string="Zavrieť" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_helpdesk_ticket_quick_create_tenenet" model="ir.ui.view">
            <field name="name">helpdesk.ticket.quick.create.tenenet</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk.quick_create_ticket_form"/>
            <field name="arch" type="xml">
                <field name="domain_user_ids" position="after">
                    <field name="legend_normal" invisible="1"/>
                    <field name="legend_blocked" invisible="1"/>
                    <field name="legend_done" invisible="1"/>
                    <field name="tenenet_assignment_domain_user_ids" invisible="1"/>
                </field>
                <field name="user_id" position="attributes">
                    <attribute name="domain">[('id', 'in', tenenet_assignment_domain_user_ids)]</attribute>
                </field>
            </field>
        </record>

        <record id="view_helpdesk_ticket_form_tenenet" model="ir.ui.view">
            <field name="name">helpdesk.ticket.form.tenenet</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
            <field name="arch" type="xml">
                <field name="company_id" position="after">
                    <field name="legend_normal" invisible="1"/>
                    <field name="legend_blocked" invisible="1"/>
                    <field name="legend_done" invisible="1"/>
                    <field name="tenenet_is_internal_team" invisible="1"/>
                    <field name="tenenet_is_helpdesk_user" invisible="1"/>
                    <field name="tenenet_is_helpdesk_editor" invisible="1"/>
                    <field name="tenenet_is_helpdesk_manager" invisible="1"/>
                    <field name="tenenet_assignment_domain_user_ids" invisible="1"/>
                    <field name="tenenet_active_assigned_user_ids" invisible="1"/>
                    <field name="tenenet_mass_assigned_user_ids" invisible="1"/>
                    <field name="tenenet_open_subtask_count" invisible="1"/>
                    <field name="tenenet_done_subtask_count" invisible="1"/>
                    <field name="tenenet_can_view_subtask_seen_info" invisible="1"/>
                    <field name="tenenet_can_confirm_followup" invisible="1"/>
                    <field name="tenenet_can_confirm_control" invisible="1"/>
                    <field name="tenenet_onboarding_id" invisible="1"/>
                    <field name="tenenet_onboarding_phase" invisible="1"/>
                    <field name="tenenet_onboarding_progress" invisible="1"/>
                    <field name="tenenet_onboarding_task_count" invisible="1"/>
                    <field name="tenenet_onboarding_task_done_count" invisible="1"/>
                    <field name="tenenet_onboarding_employee_id" invisible="1"/>
                    <field name="tenenet_onboarding_candidate_name" invisible="1"/>
                    <field name="tenenet_onboarding_job_id" invisible="1"/>
                    <field name="tenenet_onboarding_start_date" invisible="1"/>
                </field>
                <header position="inside">
                    <button
                        name="action_open_tenenet_followup_wizard"
                        string="Vyžiadať follow-up"
                        type="object"
                        class="btn-secondary"
                        invisible="not tenenet_is_internal_team or kanban_state == 'done'"
                    />
                    <button
                        name="action_open_tenenet_control_wizard"
                        string="Vyžiadať kontrolu"
                        type="object"
                        class="btn-secondary"
                        invisible="not tenenet_is_internal_team or kanban_state == 'blocked'"
                    />
                    <button
                        name="action_tenenet_confirm_followup"
                        string="Potvrdiť follow-up"
                        type="object"
                        class="btn-primary"
                        invisible="not tenenet_can_confirm_followup"
                    />
                    <button
                        name="action_tenenet_confirm_control"
                        string="Potvrdiť kontrolu"
                        type="object"
                        class="btn-primary"
                        invisible="not tenenet_can_confirm_control"
                    />
                </header>
                <field name="kanban_state" position="attributes">
                    <attribute name="invisible">tenenet_is_internal_team</attribute>
                </field>
                <field name="user_id" position="attributes">
                    <attribute name="domain">[('id', 'in', tenenet_assignment_domain_user_ids)]</attribute>
                    <attribute name="invisible">tenenet_is_internal_team</attribute>
                </field>
                <field name="description" position="after">
                    <div class="o_horizontal_separator mt-3 mb-2 text-uppercase fw-bolder small"
                         invisible="not tenenet_onboarding_id">Onboarding</div>
                    <div class="alert alert-info p-3 mb-3" invisible="not tenenet_onboarding_id">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                            <div>
                                <div class="fw-bold fs-5">
                                    <field name="tenenet_onboarding_id" readonly="1"/>
                                </div>
                                <div class="text-muted mt-1">
                                    <span invisible="not tenenet_onboarding_employee_id">
                                        <i class="fa fa-user me-1"/>
                                        <field name="tenenet_onboarding_employee_id" readonly="1"/>
                                    </span>
                                    <span invisible="tenenet_onboarding_employee_id or not tenenet_onboarding_candidate_name">
                                        <i class="fa fa-user-o me-1"/>
                                        <field name="tenenet_onboarding_candidate_name" readonly="1"/>
                                    </span>
                                    <span class="ms-3" invisible="not tenenet_onboarding_job_id">
                                        <i class="fa fa-briefcase me-1"/>
                                        <field name="tenenet_onboarding_job_id" readonly="1"/>
                                    </span>
                                    <span class="ms-3" invisible="not tenenet_onboarding_start_date">
                                        <i class="fa fa-calendar me-1"/>
                                        <field name="tenenet_onboarding_start_date" readonly="1"/>
                                    </span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <field name="tenenet_onboarding_phase" widget="badge"
                                       decoration-info="tenenet_onboarding_phase == 'pre_hire'"
                                       decoration-warning="tenenet_onboarding_phase == 'day_one'"
                                       decoration-primary="tenenet_onboarding_phase == 'first_weeks'"
                                       decoration-success="tenenet_onboarding_phase == 'done'"
                                       readonly="1"
                                       invisible="not tenenet_onboarding_id"/>
                                <button name="action_open_onboarding_tasks"
                                        type="object"
                                        class="btn btn-sm btn-secondary"
                                        invisible="not tenenet_onboarding_id">
                                    <i class="fa fa-check-square-o me-1"/>
                                    Úlohy
                                    (<field name="tenenet_onboarding_task_done_count" readonly="1" nolabel="1"/>/<field name="tenenet_onboarding_task_count" readonly="1" nolabel="1"/>)
                                </button>
                            </div>
                        </div>
                        <div class="mt-2" invisible="not tenenet_onboarding_id">
                            <field name="tenenet_onboarding_progress" readonly="1"
                                   widget="progressbar" string="Postup"/>
                        </div>
                    </div>
                </field>
                <notebook position="inside">
                    <page name="tenenet_subtasks_page" string="Čiastkové úlohy" invisible="not tenenet_is_internal_team">
                        <field
                            name="tenenet_subtask_ids"
                            mode="list"
                            context="{
                                'default_ticket_id': id,
                                'tenenet_mark_seen_on_subtask_tab_open': True,
                            }"
                        >
                            <list editable="bottom" decoration-muted="is_done">
                                <field name="sequence" widget="handle"/>
                                <button
                                    name="action_tenenet_open_subtask_form"
                                    type="object"
                                    icon="fa-external-link"
                                    title="Otvoriť"
                                />
                                <field name="priority" widget="priority" optional="show" width="70px"/>
                                <field
                                    name="is_done"
                                    widget="tenenet_subtask_done_checkmark"
                                    nolabel="1"
                                    width="20px"
                                />
                                <field name="name"/>
                                <field
                                    name="employee_ids"
                                    widget="many2many_avatar_employee"
                                    context="{'active_test': True}"
                                    domain="['|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]"
                                />
                                <field
                                    name="date_deadline"
                                    optional="show"
                                    decoration-danger="date_deadline and date_deadline &lt; current_date and not is_done"
                                />
                                <field name="can_view_seen_info" column_invisible="True"/>
                                <field name="show_seen_display" column_invisible="True"/>
                                <field name="show_seen_button" column_invisible="True"/>
                                <field name="assigned_employee_count" column_invisible="True"/>
                                <field
                                    name="single_seen_display"
                                    string="Videné"
                                    readonly="1"
                                    column_invisible="not parent.tenenet_can_view_subtask_seen_info"
                                    invisible="not show_seen_display"
                                />
                                <field name="activity_ids" string="Next Activity" widget="list_activity" optional="hide"/>
                                <field name="done_by_user_id" optional="hide" readonly="1"/>
                                <field name="done_date" optional="hide" readonly="1"/>
                            </list>
                            <form string="Čiastková úloha">
                                <header>
                                    <field
                                        name="is_done"
                                        widget="tenenet_subtask_done_checkmark"
                                        class="oe_inline"
                                    />
                                </header>
                                <sheet>
                                    <group>
                                        <field name="ticket_id" readonly="1"/>
                                        <field name="company_id" invisible="1"/>
                                        <field name="can_view_seen_info" invisible="1"/>
                                        <field name="show_seen_display" invisible="1"/>
                                        <field name="name"/>
                                        <field name="priority" widget="priority"/>
                                        <field
                                            name="employee_ids"
                                            widget="many2many_avatar_employee"
                                            context="{'active_test': True}"
                                            domain="['|', ('company_id', '=', False), ('company_id', '=', company_id)]"
                                        />
                                        <field name="date_deadline"/>
                                        <field
                                            name="single_seen_display"
                                            string="Videné"
                                            readonly="1"
                                            invisible="not show_seen_display"
                                        />
                                    </group>
                                    <field
                                        name="seen_detail_html"
                                        string="Videné"
                                        widget="html"
                                        readonly="1"
                                        nolabel="1"
                                        invisible="not can_view_seen_info"
                                    />
                                    <notebook>
                                        <page name="description" string="Popis">
                                            <field name="description" type="html" options="{'collaborative': true, 'resizable': false}"/>
                                        </page>
                                    </notebook>
                                </sheet>
                                <chatter/>
                            </form>
                        </field>
                    </page>
                </notebook>
                <field name="domain_user_ids" position="after">
                    <field
                        name="tenenet_mass_assigned_employee_ids"
                        string="Priradený"
                        widget="many2many_avatar_employee"
                        context="{'active_test': True}"
                        domain="['|', ('company_id', '=', False), ('company_id', '=', company_id)]"
                        invisible="not tenenet_is_internal_team"
                    />
                    <field name="tenenet_requested_by_user_id" readonly="1" invisible="not tenenet_is_internal_team"/>
                    <field name="tenenet_date_deadline" invisible="not tenenet_is_internal_team"/>
                    <field
                        name="tenenet_followup_user_id"
                        widget="many2one_avatar_user"
                        domain="[('id', 'in', tenenet_assignment_domain_user_ids)]"
                        invisible="not tenenet_is_internal_team or kanban_state != 'blocked'"
                    />
                    <field
                        name="tenenet_control_user_id"
                        widget="many2one_avatar_user"
                        domain="[('id', 'in', tenenet_assignment_domain_user_ids)]"
                        invisible="not tenenet_is_internal_team or kanban_state != 'done'"
                    />
                    <field name="tenenet_followup_confirmed_by_user_id" readonly="1" invisible="not tenenet_is_internal_team"/>
                    <field name="tenenet_followup_confirmed_at" readonly="1" invisible="not tenenet_is_internal_team"/>
                    <field name="tenenet_control_confirmed_by_user_id" readonly="1" invisible="not tenenet_is_internal_team"/>
                    <field name="tenenet_control_confirmed_at" readonly="1" invisible="not tenenet_is_internal_team"/>
                </field>
            </field>
        </record>

        <record id="view_helpdesk_ticket_tree_tenenet" model="ir.ui.view">
            <field name="name">helpdesk.ticket.tree.tenenet</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk.helpdesk_tickets_view_tree"/>
            <field name="arch" type="xml">
                <field name="kanban_state" position="before">
                    <field name="legend_normal" column_invisible="True"/>
                    <field name="legend_blocked" column_invisible="True"/>
                    <field name="legend_done" column_invisible="True"/>
                    <field name="tenenet_active_assigned_user_ids" column_invisible="True"/>
                    <field name="tenenet_mass_assigned_user_ids" column_invisible="True"/>
                </field>
                <field name="user_id" position="attributes">
                    <attribute name="optional">hide</attribute>
                </field>
                <field name="user_id" position="after">
                    <field name="tenenet_mass_assigned_employee_ids" string="Priradený" optional="show" widget="many2many_avatar_employee"/>
                    <field name="tenenet_requested_by_user_id" optional="hide"/>
                    <field name="tenenet_followup_user_id" optional="hide" widget="many2one_avatar_user"/>
                    <field name="tenenet_control_user_id" optional="hide" widget="many2one_avatar_user"/>
                </field>
            </field>
        </record>

        <record id="view_helpdesk_ticket_kanban_tenenet" model="ir.ui.view">
            <field name="name">helpdesk.ticket.kanban.tenenet</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_kanban"/>
            <field name="arch" type="xml">
                <kanban position="inside">
                    <field name="legend_normal"/>
                    <field name="legend_blocked"/>
                    <field name="legend_done"/>
                    <field name="tenenet_is_internal_team"/>
                    <field name="tenenet_active_assigned_user_ids"/>
                    <field name="tenenet_mass_assigned_employee_ids"/>
                    <field name="tenenet_mass_assigned_user_ids"/>
                    <field name="tenenet_requested_by_user_id"/>
                    <field name="tenenet_followup_user_id"/>
                    <field name="tenenet_control_user_id"/>
                    <header>
                        <button
                            string="Hromadný ticket"
                            class="btn btn-primary"
                            type="action"
                            display="always"
                            name="tenenet_projects.action_tenenet_helpdesk_mass_ticket_wizard"
                            groups="tenenet_projects.group_tenenet_helpdesk_manager,base.group_system"
                        />
                    </header>
                </kanban>
                <field name="properties" position="after">
                    <t t-if="record.tenenet_is_internal_team.raw_value">
                        <div class="text-muted small">
                            Vytvoril: <field name="tenenet_requested_by_user_id"/>
                        </div>
                        <div class="text-muted small" t-if="record.tenenet_mass_assigned_employee_ids.raw_value.length">
                            Priradení: <field name="tenenet_mass_assigned_employee_ids" widget="many2many_tags"/>
                        </div>
                        <div
                            class="text-muted small"
                            t-if="record.kanban_state.raw_value == 'blocked' and record.tenenet_followup_user_id.raw_value"
                        >
                            Follow-up: <field name="tenenet_followup_user_id"/>
                        </div>
                        <div
                            class="text-muted small"
                            t-if="record.kanban_state.raw_value == 'done' and record.tenenet_control_user_id.raw_value"
                        >
                            Kontrola: <field name="tenenet_control_user_id"/>
                        </div>
                    </t>
                </field>
            </field>
        </record>

        <record id="view_helpdesk_ticket_search_tenenet" model="ir.ui.view">
            <field name="name">helpdesk.ticket.search.tenenet</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk.helpdesk_tickets_view_search"/>
            <field name="arch" type="xml">
                <field name="user_id" position="after">
                    <field name="tenenet_requested_by_user_id"/>
                    <field name="tenenet_followup_user_id"/>
                    <field name="tenenet_control_user_id"/>
                </field>
                <filter name="my_ticket" position="attributes">
                    <attribute name="string">Moje pridelené</attribute>
                    <attribute name="domain">[('tenenet_active_assigned_user_ids', 'in', uid)]</attribute>
                </filter>
                <filter name="my_follow_ticket" position="after">
                    <filter string="Moje interné TENENET" name="tenenet_internal" domain="[('team_id.name', '=', 'Interné TENENET')]"/>
                    <filter string="Mnou vytvorené" name="tenenet_requested_by_me" domain="[('tenenet_requested_by_user_id', '=', uid)]"/>
                    <filter string="Follow-up na mne" name="tenenet_followup_me" domain="[('tenenet_followup_user_id', '=', uid)]"/>
                    <filter string="Kontrola na mne" name="tenenet_control_me" domain="[('tenenet_control_user_id', '=', uid)]"/>
                </filter>
            </field>
        </record>
    </data>
</odoo>
