<odoo>
    <data>
        <record id="view_tenenet_operating_cost_pool_list" model="ir.ui.view">
            <field name="name">tenenet.operating.cost.pool.list</field>
            <field name="model">tenenet.operating.cost.pool</field>
            <field name="arch" type="xml">
                <list string="Pool prevádzkových nákladov">
                    <field name="year"/>
                    <field name="basis_year"/>
                    <field name="annual_amount"/>
                    <field name="is_locked"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_operating_cost_pool_form" model="ir.ui.view">
            <field name="name">tenenet.operating.cost.pool.form</field>
            <field name="model">tenenet.operating.cost.pool</field>
            <field name="arch" type="xml">
                <form string="Pool prevádzkových nákladov">
                    <sheet>
                        <group>
                            <group>
                                <field name="year"/>
                                <field name="basis_year"/>
                                <field name="annual_amount"/>
                                <field name="is_locked"/>
                            </group>
                            <group>
                                <field name="source_note"/>
                            </group>
                        </group>
                        <div class="mb-2">
                            <button name="action_rebuild_allocations"
                                    type="object"
                                    string="Prepočítať alokácie"
                                    class="btn btn-primary"/>
                        </div>
                        <field name="allocation_ids" nolabel="1">
                            <list string="Alokácie" create="0" delete="0" edit="0">
                                <field name="period"/>
                                <field name="program_id"/>
                                <field name="allocation_basis_fte"/>
                                <field name="allocation_pct"/>
                                <field name="amount"/>
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_operating_cost_pool_search" model="ir.ui.view">
            <field name="name">tenenet.operating.cost.pool.search</field>
            <field name="model">tenenet.operating.cost.pool</field>
            <field name="arch" type="xml">
                <search string="Pool prevádzkových nákladov">
                    <field name="year"/>
                    <field name="basis_year"/>
                </search>
            </field>
        </record>

        <record id="action_tenenet_operating_cost_pool" model="ir.actions.act_window">
            <field name="name">Prevádzkové náklady</field>
            <field name="res_model">tenenet.operating.cost.pool</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_tenenet_operating_cost_pool_search"/>
        </record>
    </data>
</odoo>
