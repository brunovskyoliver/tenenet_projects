<odoo>
    <data>
        <record id="view_tenenet_project_milestone_wizard_form" model="ir.ui.view">
            <field name="name">tenenet.project.milestone.wizard.form</field>
            <field name="model">tenenet.project.milestone.wizard</field>
            <field name="arch" type="xml">
                <form string="Míľnik projektu">
                    <sheet>
                        <group>
                            <field name="project_id" readonly="1"/>
                            <field name="date"/>
                            <field name="name"/>
                            <field name="note"/>
                        </group>
                        <separator string="Prílohy"/>
                        <field name="attachment_ids"
                               widget="many2many_binary"
                               string="Prílohy"
                               nolabel="1"/>
                        <separator string="Upozornenie"/>
                        <group>
                            <group>
                                <label for="alert_lead_amount" string="Upozorniť pred"/>
                                <div class="o_field_widget d-flex gap-2">
                                    <field name="alert_lead_amount" class="o_field_integer"/>
                                    <field name="alert_lead_unit" class="o_field_select"/>
                                </div>
                            </group>
                        </group>
                        <group>
                            <field name="alert_partner_ids"
                                   widget="many2many_tags"
                                   string="Príjemcovia"
                                   options="{'no_create': True}"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirm"
                                type="object"
                                string="Uložiť"
                                class="btn-primary"/>
                        <button name="action_delete"
                                type="object"
                                string="Vymazať"
                                class="btn-secondary"
                                invisible="not milestone_id"/>
                        <button string="Zrušiť" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
