<odoo>
    <data>
        <record id="view_tenenet_project_cashflow_distribute_wizard_form" model="ir.ui.view">
            <field name="name">tenenet.project.cashflow.distribute.wizard.form</field>
            <field name="model">tenenet.project.cashflow.distribute.wizard</field>
            <field name="arch" type="xml">
                <form string="Distribuovať cashflow">
                    <group>
                        <field name="receipt_id" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="project_id" readonly="1"/>
                        <field name="amount"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <footer>
                        <button name="action_distribute"
                                type="object"
                                string="Distribuovať"
                                class="btn btn-primary"/>
                        <button string="Zrušiť"
                                class="btn btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
