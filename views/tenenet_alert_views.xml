<odoo>
    <data>
        <record id="view_tenenet_alert_rule_search" model="ir.ui.view">
            <field name="name">tenenet.alert.rule.search</field>
            <field name="model">tenenet.alert.rule</field>
            <field name="arch" type="xml">
                <search string="Pravidlá upozornení">
                    <field name="name"/>
                    <field name="allowed_model_id"/>
                    <filter string="Aktívne" name="active" domain="[('active', '=', True)]"/>
                    <filter string="S chybou" name="with_error" domain="[('last_error', '!=', False)]"/>
                    <filter string="So zhodami" name="with_matches" domain="[('match_count', '>', 0)]"/>
                    <filter string="Spustené dnes" name="run_today" domain="[('last_run_at', '>=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                    <group>
                        <filter string="Model" name="group_model" context="{'group_by': 'allowed_model_id'}"/>
                        <filter string="Aktívne" name="group_active" context="{'group_by': 'active'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_tenenet_alert_rule_kanban" model="ir.ui.view">
            <field name="name">tenenet.alert.rule.kanban</field>
            <field name="model">tenenet.alert.rule</field>
            <field name="arch" type="xml">
                <kanban default_order="sequence, name">
                    <field name="name"/>
                    <field name="allowed_model_id"/>
                    <field name="active"/>
                    <field name="match_count"/>
                    <field name="last_run_at"/>
                    <field name="last_error"/>
                    <templates>
                        <t t-name="card">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <strong t-out="record.name.value"/>
                                <t t-if="record.active.raw_value">
                                    <span class="badge bg-success">Aktívne</span>
                                </t>
                                <t t-else="">
                                    <span class="badge bg-secondary">Neaktívne</span>
                                </t>
                            </div>
                            <div class="small text-muted mb-1">
                                <field name="allowed_model_id"/>
                            </div>
                            <div class="small mb-1">
                                Zhody: <t t-out="record.match_count.value or 0"/>
                            </div>
                            <div class="small text-muted mb-1">
                                Posledné spustenie: <t t-out="record.last_run_at.value or '-'"/>
                            </div>
                            <t t-if="record.last_error.raw_value">
                                <div class="small text-danger">
                                    Chyba: <t t-out="record.last_error.value"/>
                                </div>
                            </t>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_tenenet_alert_rule_list" model="ir.ui.view">
            <field name="name">tenenet.alert.rule.list</field>
            <field name="model">tenenet.alert.rule</field>
            <field name="arch" type="xml">
                <list string="Pravidlá upozornení">
                    <field name="sequence" optional="hide"/>
                    <field name="name"/>
                    <field name="allowed_model_id"/>
                    <field name="active"/>
                    <field name="match_count"/>
                    <field name="last_run_at"/>
                    <field name="last_new_match_count"/>
                    <field name="last_mail_sent_at"/>
                    <button name="action_run_now" type="object" string="Spustiť teraz" class="btn-link"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_alert_condition_list" model="ir.ui.view">
            <field name="name">tenenet.alert.condition.list</field>
            <field name="model">tenenet.alert.condition</field>
            <field name="arch" type="xml">
                <list string="Podmienky" delete="0" create="0" open_form_view="0">
                    <field name="sequence" widget="handle"/>
                    <field name="field_id"/>
                    <field name="condition_summary"/>
                    <button name="action_open_condition_wizard" type="object" string="Upraviť" class="btn-link"/>
                    <button name="action_delete_condition" type="object" string="Odstrániť" class="btn-link text-danger"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_alert_rule_form" model="ir.ui.view">
            <field name="name">tenenet.alert.rule.form</field>
            <field name="model">tenenet.alert.rule</field>
            <field name="arch" type="xml">
                <form string="Pravidlo upozornenia">
                    <header>
                        <button name="action_run_now" type="object" string="Spustiť teraz" class="btn-primary"/>
                        <field name="active" widget="boolean_toggle"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="allowed_model_id"/>
                            </group>
                            <group>
                                <field name="last_run_at" readonly="1"/>
                                <field name="last_mail_sent_at" readonly="1"/>
                                <field name="last_new_match_count" readonly="1"/>
                                <field name="match_count" readonly="1"/>
                            </group>
                        </group>
                        <group invisible="not last_error">
                            <field name="last_error" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Podmienky">
                                <button name="action_open_new_condition_wizard" type="object" string="Pridať podmienku" class="btn-primary"/>
                                <field name="condition_ids" context="{'default_rule_id': id}" mode="list" readonly="1" nolabel="1">
                                    <list delete="0" create="0" open_form_view="0" string="Podmienky">
                                        <field name="sequence" widget="handle"/>
                                        <field name="field_id"/>
                                        <field name="condition_summary"/>
                                        <button name="action_open_condition_wizard" type="object" string="Upraviť" class="btn-link"/>
                                        <button name="action_delete_condition" type="object" string="Odstrániť" class="btn-link text-danger"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Príjemcovia">
                                <group>
                                    <group>
                                        <field name="recipient_email_raw" placeholder="meno@example.com&#10;dalsi@example.com"/>
                                    </group>
                                    <group>
                                        <field name="recipient_partner_ids" widget="many2many_tags"/>
                                        <field name="recipient_field_ids" widget="many2many_tags"/>
                                        <field name="summary_field_ids" widget="many2many_tags"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Aktívne zhody">
                                <field name="active_match_ids" readonly="1">
                                    <list string="Aktívne zhody">
                                        <field name="res_model"/>
                                        <field name="res_id"/>
                                        <field name="last_display_name"/>
                                        <field name="first_matched_at"/>
                                        <field name="last_seen_at"/>
                                        <field name="last_notified_at"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Popis">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_tenenet_alert_rule" model="ir.actions.act_window">
            <field name="name">Pravidlá upozornení</field>
            <field name="res_model">tenenet.alert.rule</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'sequence': 1, 'view_mode': 'kanban', 'view_id': ref('view_tenenet_alert_rule_kanban')}),
                (0, 0, {'sequence': 2, 'view_mode': 'list', 'view_id': ref('view_tenenet_alert_rule_list')}),
                (0, 0, {'sequence': 3, 'view_mode': 'form', 'view_id': ref('view_tenenet_alert_rule_form')})
            ]"/>
            <field name="search_view_id" ref="view_tenenet_alert_rule_search"/>
            <field name="context">{'search_default_active': 1}</field>
        </record>

        <record id="view_tenenet_alert_condition_wizard_form" model="ir.ui.view">
            <field name="name">tenenet.alert.condition.wizard.form</field>
            <field name="model">tenenet.alert.condition.wizard</field>
            <field name="arch" type="xml">
                <form string="Podmienka upozornenia">
                    <group>
                        <group>
                            <field name="rule_id" invisible="1"/>
                            <field name="target_model_id" invisible="1"/>
                            <field name="condition_id" invisible="1"/>
                            <field name="sequence"/>
                            <field name="field_id"
                                   domain="[('model_id', '=', target_model_id), ('store', '=', True), ('ttype', 'in', ['date','datetime','char','text','integer','float','monetary','boolean','selection','many2one'])]"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="operator_text" invisible="field_ttype not in ['char', 'text']"/>
                            <field name="operator_numeric" invisible="field_ttype not in ['integer', 'float', 'monetary']"/>
                            <field name="operator_boolean" invisible="field_ttype != 'boolean'"/>
                            <field name="operator_selection" invisible="field_ttype != 'selection'"/>
                            <field name="operator_many2one" invisible="field_ttype != 'many2one'"/>
                            <field name="operator_date" invisible="field_ttype not in ['date', 'datetime']"/>
                        </group>
                        <group>
                            <field name="value_char" invisible="not show_text_value"/>
                            <field name="value_text" invisible="not show_textarea_value"/>
                            <field name="value_integer" invisible="not show_integer_value"/>
                            <field name="value_float" invisible="not show_float_value"/>
                            <field name="selection_item_id" invisible="not show_selection_value" options="{'no_create': True, 'no_open': True}"/>
                            <field name="value_reference" widget="reference" invisible="not show_reference_value"/>
                            <field name="value_date" invisible="not show_date_value"/>
                            <field name="value_datetime" invisible="not show_datetime_value"/>
                            <field name="relative_amount" invisible="not show_relative_value"/>
                            <field name="relative_unit" invisible="not show_relative_value"/>
                        </group>
                    </group>
                    <footer>
                        <button string="Uložiť" type="object" name="action_save" class="btn-primary"/>
                        <button string="Zrušiť" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
