<odoo>
    <data>
        <record id="tenenet_employee_list_report" model="account.report">
            <field name="name">Zoznam zamestnancov</field>
            <field name="load_more_limit">200</field>
            <field name="search_bar" eval="True" />
            <field name="filter_date_range" eval="True" />
            <field name="filter_show_draft" eval="False" />
            <field name="filter_unreconciled" eval="False" />
            <field name="filter_unfold_all" eval="False" />
            <field name="filter_hide_0_lines">never</field>
            <field name="filter_period_comparison" eval="False" />
            <field name="filter_growth_comparison" eval="False" />
            <field name="filter_journals" eval="False" />
            <field name="filter_analytic" eval="False" />
            <field name="filter_hierarchy">never</field>
            <field name="filter_account_type">disabled</field>
            <field name="filter_partner" eval="False" />
            <field name="filter_aml_ir_filters" eval="False" />
            <field name="default_opening_date_filter">this_month</field>
            <field
                name="custom_handler_model_id"
                ref="model_tenenet_employee_list_report_handler"
            />
            <field name="column_ids">
                <record
                    id="tenenet_employee_list_report_column_employee_name"
                    model="account.report.column"
                >
                    <field name="sequence">5</field>
                    <field name="name">Zamestnanec</field>
                    <field name="expression_label">employee_name</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_number"
                    model="account.report.column"
                >
                    <field name="sequence">10</field>
                    <field name="name">Číslo</field>
                    <field name="expression_label">tenenet_number</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_title"
                    model="account.report.column"
                >
                    <field name="sequence">20</field>
                    <field name="name">Titul</field>
                    <field name="expression_label">title_academic</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_last_name"
                    model="account.report.column"
                >
                    <field name="sequence">30</field>
                    <field name="name">Priezvisko</field>
                    <field name="expression_label">last_name</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_first_name"
                    model="account.report.column"
                >
                    <field name="sequence">40</field>
                    <field name="name">Meno</field>
                    <field name="expression_label">first_name</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_position"
                    model="account.report.column"
                >
                    <field name="sequence">50</field>
                    <field name="name">Pozícia</field>
                    <field name="expression_label">position</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_all_jobs"
                    model="account.report.column"
                >
                    <field name="sequence">52</field>
                    <field name="name">Pozície</field>
                    <field name="expression_label">all_job_names</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_phone"
                    model="account.report.column"
                >
                    <field name="sequence">55</field>
                    <field name="name">Telefón</field>
                    <field name="expression_label">work_phone</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_education"
                    model="account.report.column"
                >
                    <field name="sequence">60</field>
                    <field name="name">Vzdelanie</field>
                    <field name="expression_label">study_field</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_manager"
                    model="account.report.column"
                >
                    <field name="sequence">70</field>
                    <field name="name">Priamy nadriadený</field>
                    <field name="expression_label">manager_name</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_main_site"
                    model="account.report.column"
                >
                    <field name="sequence">71</field>
                    <field name="name">Hlavné miesto práce</field>
                    <field name="expression_label">main_site_name</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_secondary_sites"
                    model="account.report.column"
                >
                    <field name="sequence">71</field>
                    <field name="name">Vedľajšie miesta práce</field>
                    <field name="expression_label">secondary_site_names</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_projects"
                    model="account.report.column"
                >
                    <field name="sequence">72</field>
                    <field name="name">Projekty</field>
                    <field name="expression_label">project_names</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_programs"
                    model="account.report.column"
                >
                    <field name="sequence">73</field>
                    <field name="name">Programy</field>
                    <field name="expression_label">program_names</field>
                    <field name="figure_type">string</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_availability"
                    model="account.report.column"
                >
                    <field name="sequence">74</field>
                    <field name="name">Dostupnosť</field>
                    <field name="expression_label">free_hours</field>
                    <field name="figure_type">float</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_utilization_percentage"
                    model="account.report.column"
                >
                    <field name="sequence">75</field>
                    <field name="name">Vyťaženosť</field>
                    <field
                        name="expression_label"
                    >utilization_percentage</field>
                    <field name="figure_type">percentage</field>
                </record>
                <record
                    id="tenenet_employee_list_report_column_work_hours"
                    model="account.report.column"
                >
                    <field name="sequence">80</field>
                    <field name="name">Denný úväzok (hod.)</field>
                    <field name="expression_label">work_hours</field>
                    <field name="figure_type">float</field>
                </record>
            </field>
        </record>

        <delete
            id="tenenet_projects.tenenet_employee_list_report_column_free_hours"
            model="account.report.column"
        />

        <record
            id="action_tenenet_employee_list_report"
            model="ir.actions.client"
        >
            <field name="name">Zoznam zamestnancov</field>
            <field name="tag">account_report</field>
            <field name="path">tenenet-employee-list-report</field>
            <field
                name="context"
                eval="{'report_id': ref('tenenet_projects.tenenet_employee_list_report')}"
            />
        </record>
    </data>
</odoo>
