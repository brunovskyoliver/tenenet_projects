<odoo>
    <data>
        <record id="view_tenenet_expense_type_config_list" model="ir.ui.view">
            <field name="name">tenenet.expense.type.config.list</field>
            <field name="model">tenenet.expense.type.config</field>
            <field name="arch" type="xml">
                <list string="Typy projektových nákladov" editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="hr_expense_product_id"/>
                    <field name="description"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_expense_type_config_form" model="ir.ui.view">
            <field name="name">tenenet.expense.type.config.form</field>
            <field name="model">tenenet.expense.type.config</field>
            <field name="arch" type="xml">
                <form string="Typ projektového nákladu">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="hr_expense_product_id" readonly="1"/>
                        </group>
                        <group string="Popis">
                            <field name="description" nolabel="1"/>
                        </group>
                        <group string="HR kategórie výdavkov">
                            <field name="expense_category_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_tenenet_expense_type_config" model="ir.actions.act_window">
            <field name="name">Typy projektových nákladov</field>
            <field name="res_model">tenenet.expense.type.config</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
