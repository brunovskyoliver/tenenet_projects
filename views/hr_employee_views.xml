<odoo>
    <data>
        <record id="view_hr_employee_tenenet_list" model="ir.ui.view">
            <field name="name">hr.employee.tenenet.list</field>
            <field name="model">hr.employee</field>
            <field name="arch" type="xml">
                <list string="Zamestnanci">
                    <field name="name" />
                    <field name="job_id" />
                    <field name="tenenet_allocation_ratio_total" />
                    <field name="tenenet_free_ratio" />
                    <field
                        name="tenenet_availability_state"
                        widget="badge"
                        decoration-success="tenenet_availability_state == 'free'"
                        decoration-info="tenenet_availability_state == 'partial'"
                        decoration-warning="tenenet_availability_state == 'full'"
                        decoration-danger="tenenet_availability_state == 'overbooked'"
                    />
                </list>
            </field>
        </record>

        <record id="view_hr_employee_tenenet_search" model="ir.ui.view">
            <field name="name">hr.employee.tenenet.search</field>
            <field name="model">hr.employee</field>
            <field name="arch" type="xml">
                <search string="Zamestnanci">
                    <field name="name" />
                    <field name="job_id" />
                    <filter
                        string="Voľní"
                        name="free"
                        domain="[('tenenet_availability_state', '=', 'free')]"
                    />
                    <filter
                        string="V projekte"
                        name="in_project"
                        domain="[('tenenet_availability_state', 'in', ['partial', 'full', 'overbooked'])]"
                    />
                    <filter
                        string="Čiastočne alokovaní"
                        name="partial"
                        domain="[('tenenet_availability_state', '=', 'partial')]"
                    />
                    <filter
                        string="Preťažení"
                        name="overbooked"
                        domain="[('tenenet_availability_state', '=', 'overbooked')]"
                    />
                    <group>
                        <filter
                            string="Profesie"
                            name="group_job"
                            context="{'group_by': 'job_id'}"
                        />
                        <filter
                            string="Stav dostupnosti"
                            name="group_availability"
                            context="{'group_by': 'tenenet_availability_state'}"
                        />
                    </group>
                </search>
            </field>
        </record>

        <record id="view_hr_employee_form_tenenet" model="ir.ui.view">
            <field name="name">hr.employee.form.tenenet</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form" />
            <field name="arch" type="xml">
                <xpath expr="//page[@name='work_information']" position="after">
                    <page string="Služby">
                        <field name="can_manage_services" invisible="1" />
                        <separator
                            string="Služby, ktoré zamestnanec poskytuje"
                        />
                        <field
                            name="service_ids"
                            nolabel="1"
                            readonly="not can_manage_services"
                            context="{'default_employee_id': id}"
                            colspan="2"
                        >
                            <list string="Služby" editable="bottom">
                                <field name="sequence" widget="handle" />
                                <field
                                    name="service_catalog_id"
                                    string="Služba"
                                />
                                <field name="active" />
                            </list>
                            <form string="Služba">
                                <sheet>
                                    <group col="1">
                                        <field
                                            name="employee_id"
                                            invisible="1"
                                        />
                                        <field
                                            name="service_catalog_id"
                                            string="Služba"
                                        />
                                        <field name="active" />
                                    </group>
                                    <group>
                                        <field name="description" />
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </page>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="TENENET">
                        <group>
                            <group>
                                <field name="work_ratio" string="Úväzok (%)" />
                            </group>
                            <group>
                                <field name="hourly_rate" />
                                <field
                                    name="tenenet_allocation_ratio_total"
                                    readonly="1"
                                    string="Projektový podiel spolu (%)"
                                />
                                <field name="tenenet_free_ratio" readonly="1" />
                                <field
                                    name="tenenet_availability_state"
                                    readonly="1"
                                    widget="badge"
                                />
                            </group>
                        </group>
                        <div class="o_tenenet_employee_assignments mt-4">
                            <div class="o_form_label mb-2">
                                Priradenia k projektom
                            </div>
                            <field
                                name="assignment_ids"
                                nolabel="1"
                                readonly="1"
                                colspan="2"
                                domain="[('is_current', '=', True)]"
                                class="o_tenenet_employee_assignments_field"
                            >
                                <list
                                    string="Priradenia k projektom"
                                    class="o_tenenet_employee_assignments_list"
                                >
                                    <field name="project_id" />
                                    <field
                                        name="allocation_ratio"
                                        string="Úväzok (%)"
                                    />
                                    <field
                                        name="date_start"
                                        string="Začiatok"
                                    />
                                    <field
                                        name="date_end"
                                        string="Koniec"
                                    />
                                    <field
                                        name="wage_hm"
                                        string="HM / hod."
                                    />
                                    <button
                                        name="action_open_timesheet_matrix_current_year"
                                        type="object"
                                        string="Otvoriť maticu"
                                        class="btn-link"
                                    />
                                </list>
                            </field>
                        </div>
                    </page>
                    <page string="Firemný majetok">
                        <group>
                            <group>
                                <field name="asset_total_value" readonly="1"/>
                            </group>
                        </group>
                        <separator string="Majetok"/>
                        <field
                            name="asset_ids"
                            nolabel="1"
                            context="{'default_employee_id': id}"
                            colspan="2"
                        >
                            <list string="Firemný majetok" editable="bottom">
                                <field name="asset_type_id"/>
                                <field name="currency_id" column_invisible="1"/>
                                <field name="cost" optional="show"/>
                                <field name="note" optional="show"/>
                                <field name="active"/>
                            </list>
                            <form string="Položka majetku">
                                <sheet>
                                    <group>
                                        <field name="employee_id" invisible="1"/>
                                        <field name="asset_type_id"/>
                                        <field name="currency_id"/>
                                        <field name="cost"/>
                                        <field name="active"/>
                                    </group>
                                    <group>
                                        <field name="note"/>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                        <separator string="Kľúče"/>
                        <field
                            name="site_key_ids"
                            nolabel="1"
                            context="{'default_employee_id': id}"
                            colspan="2"
                        >
                            <list string="Kľúče" editable="bottom">
                                <field name="site_id" domain="[('site_type', 'in', ['prevadzka', 'centrum'])]"/>
                                <field name="note" optional="show"/>
                                <field name="active"/>
                            </list>
                            <form string="Kľúč">
                                <sheet>
                                    <group>
                                        <field name="employee_id" invisible="1"/>
                                        <field name="site_id" domain="[('site_type', 'in', ['prevadzka', 'centrum'])]"/>
                                        <field name="active"/>
                                    </group>
                                    <group>
                                        <field name="note"/>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </page>
                </xpath>

                <xpath
                    expr="//page[@name='resume']//div[@id='o_employee_left']"
                    position="inside"
                >
                    <group string="TENENET školenia">
                        <field
                            name="training_ids"
                            nolabel="1"
                            context="{'default_employee_id': id}"
                        >
                            <list string="Školenia">
                                <field name="name" />
                                <field name="training_type" />
                                <field name="provider" />
                                <field name="date_from" />
                                <field name="date_to" />
                                <field name="certificate_date" />
                                <field name="active" />
                            </list>
                            <form string="Školenie">
                                <sheet>
                                    <group>
                                        <group>
                                            <field
                                                name="employee_id"
                                                invisible="1"
                                            />
                                            <field name="name" />
                                            <field name="training_type" />
                                            <field name="provider" />
                                        </group>
                                        <group>
                                            <field name="date_from" />
                                            <field name="date_to" />
                                            <field name="certificate_date" />
                                            <field name="active" />
                                        </group>
                                    </group>
                                    <group>
                                        <field name="notes" />
                                    </group>
                                </sheet>
                                <chatter
                                    open_attachments="True"
                                    reload_on_attachment="True"
                                />
                            </form>
                        </field>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="view_hr_employee_public_form_tenenet" model="ir.ui.view">
            <field name="name">hr.employee.public.form.tenenet</field>
            <field name="model">hr.employee.public</field>
            <field name="inherit_id" ref="hr.hr_employee_public_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//page[@name='work_information']" position="after">
                    <page string="Služby">
                        <separator
                            string="Služby, ktoré zamestnanec poskytuje"
                        />
                        <field name="service_ids" nolabel="1" colspan="2">
                            <list string="Služby">
                                <field name="name" string="Služba" />
                                <field name="active" />
                            </list>
                            <form string="Služba">
                                <sheet>
                                    <group col="1">
                                        <field
                                            name="name"
                                            string="Služba"
                                            readonly="1"
                                        />
                                        <field name="active" readonly="1" />
                                    </group>
                                    <group>
                                        <field
                                            name="description"
                                            readonly="1"
                                        />
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="action_tenenet_employees" model="ir.actions.act_window">
            <field name="name">Zamestnanci</field>
            <field name="res_model">hr.employee</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_hr_employee_tenenet_list" />
            <field
                name="search_view_id"
                ref="view_hr_employee_tenenet_search"
            />
        </record>
    </data>
</odoo>
