<odoo>
    <data>
        <record id="view_hr_employee_tenenet_list" model="ir.ui.view">
            <field name="name">hr.employee.tenenet.list</field>
            <field name="model">hr.employee</field>
            <field name="arch" type="xml">
                <list string="Zamestnanci" default_order="main_site_id,tenenet_number,last_name,first_name,name">
                    <field name="title_academic" string="Titul" optional="show" />
                    <field name="name" />
                    <field name="organizational_unit_id" optional="show" />
                    <field name="main_site_id" optional="show" />
                    <field name="all_job_names" string="Pozície" optional="show" />
                    <field name="all_site_names" string="Miesta práce" optional="hide" />
                    <field name="tenenet_allocation_ratio_total" />
                    <field name="tenenet_free_ratio" />
                    <field
                        name="tenenet_availability_state"
                        widget="badge"
                        decoration-success="tenenet_availability_state == 'free'"
                        decoration-info="tenenet_availability_state == 'partial'"
                        decoration-warning="tenenet_availability_state == 'full'"
                        decoration-danger="tenenet_availability_state == 'overbooked'"
                    />
                </list>
            </field>
        </record>

        <record id="view_hr_employee_tree_tenenet_title_before_name" model="ir.ui.view">
            <field name="name">hr.employee.tree.tenenet.title.before.name</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="before">
                    <field name="title_academic" string="Title" optional="show"/>
                </xpath>
            </field>
        </record>

        <record id="hr_employee_list_view_tenenet_title_before_name" model="ir.ui.view">
            <field name="name">hr.employee.list.tenenet.title.before.name</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.hr_employee_list_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="before">
                    <field name="title_academic" string="Title" optional="show"/>
                </xpath>
            </field>
        </record>

        <record id="hr_employee_list_activities_view_tenenet_title_before_name" model="ir.ui.view">
            <field name="name">hr.employee.list.activities.tenenet.title.before.name</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.hr_employee_list_activites_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="before">
                    <field name="title_academic" string="Title" optional="show"/>
                </xpath>
            </field>
        </record>

        <record id="view_hr_employee_tenenet_search" model="ir.ui.view">
            <field name="name">hr.employee.tenenet.search</field>
            <field name="model">hr.employee</field>
            <field name="arch" type="xml">
                <search string="Zamestnanci">
                    <field name="name" />
                    <field name="organizational_unit_id" />
                    <field name="job_id" />
                    <field name="main_site_id" />
                    <field name="all_job_names" />
                    <filter
                        string="Voľní"
                        name="free"
                        domain="[('tenenet_availability_state', '=', 'free')]"
                    />
                    <filter
                        string="V projekte"
                        name="in_project"
                        domain="[('tenenet_availability_state', 'in', ['partial', 'full', 'overbooked'])]"
                    />
                    <filter
                        string="Čiastočne alokovaní"
                        name="partial"
                        domain="[('tenenet_availability_state', '=', 'partial')]"
                    />
                    <filter
                        string="Preťažení"
                        name="overbooked"
                        domain="[('tenenet_availability_state', '=', 'overbooked')]"
                    />
                    <group>
                        <filter
                            string="Profesie"
                            name="group_job"
                            context="{'group_by': 'job_id'}"
                        />
                        <filter
                            string="Hlavné pracovisko"
                            name="group_main_site"
                            context="{'group_by': 'main_site_id'}"
                        />
                        <filter
                            string="Stav dostupnosti"
                            name="group_availability"
                            context="{'group_by': 'tenenet_availability_state'}"
                        />
                    </group>
                </search>
            </field>
        </record>

        <record id="view_hr_employee_form_tenenet" model="ir.ui.view">
            <field name="name">hr.employee.form.tenenet</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form" />
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <field name="tenenet_is_card_owner" invisible="1"/>
                    <field name="tenenet_is_employee_higher_up" invisible="1"/>
                    <field name="tenenet_is_project_manager_viewer" invisible="1"/>
                    <field name="tenenet_can_edit_self_employee_fields" invisible="1"/>
                    <field name="tenenet_can_request_employee_update" invisible="1"/>
                    <field name="tenenet_weekly_site_domain_ids" invisible="1"/>
                </xpath>

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button
                        name="action_tenenet_open_employee_update_request_wizard"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-refresh"
                        invisible="not tenenet_can_request_employee_update"
                    >
                        <div class="o_stat_info">
                            <span class="o_stat_text">Aktualizovať</span>
                        </div>
                    </button>
                    <button
                        name="action_open_onboardings"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-users"
                        invisible="tenenet_onboarding_count == 0"
                    >
                        <field name="tenenet_onboarding_count" widget="statinfo" string="Onboarding"/>
                    </button>
                </xpath>

                <xpath expr="//page[@name='work_information']//group[@name='note']" position="replace">
                    <group string="Poznámka" name="note">
                        <field
                            name="additional_note"
                            placeholder="Doplňujúca poznámka k práci zamestnanca."
                            colspan="2"
                            nolabel="1"
                            readonly="not tenenet_can_edit_self_employee_fields"
                        />
                    </group>
                </xpath>

                <xpath expr="//page[@name='personal_information']" position="attributes">
                    <attribute name="groups"/>
                </xpath>

                <xpath expr="//page[@name='payroll_information']" position="attributes">
                    <attribute name="groups"/>
                </xpath>

                <xpath expr="//page[@name='hr_settings']" position="attributes">
                    <attribute name="groups"/>
                </xpath>

                <xpath expr="//page[@name='work_information']" position="after">
                    <page string="Služby">
                        <field name="can_manage_services" invisible="1" />
                        <separator
                            string="Služby, ktoré zamestnanec poskytuje"
                        />
                        <field
                            name="service_ids"
                            nolabel="1"
                            readonly="not can_manage_services"
                            context="{'default_employee_id': id}"
                            colspan="2"
                        >
                            <list string="Služby" editable="bottom">
                                <field name="sequence" widget="handle" />
                                <field
                                    name="service_catalog_id"
                                    string="Služba"
                                />
                                <field name="delivery_online" />
                                <field name="delivery_in_person" />
                                <field name="active" />
                            </list>
                            <form string="Služba">
                                <sheet>
                                    <group col="1">
                                        <field
                                            name="employee_id"
                                            invisible="1"
                                        />
                                        <field
                                            name="service_catalog_id"
                                            string="Služba"
                                        />
                                        <field name="delivery_online" />
                                        <field name="delivery_in_person" />
                                        <field name="active" />
                                    </group>
                                    <group>
                                        <field name="description" />
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </page>
                </xpath>

                <xpath expr="//page[@name='work_information']//field[@name='job_id']" position="after">
                    <field name="organizational_unit_id" readonly="not can_manage_services" />
                    <field
                        name="additional_job_ids"
                        widget="many2many_tags"
                        string="Ďalšie pozície"
                        readonly="not can_manage_services"
                    />
                </xpath>

                <xpath expr="//page[@name='work_information']//field[@name='job_id']" position="attributes">
                    <attribute name="readonly">not can_manage_services</attribute>
                </xpath>

                <xpath expr="//page[@name='work_information']//field[@name='company_id']" position="attributes">
                    <attribute name="readonly">not can_manage_services</attribute>
                </xpath>

                <xpath expr="//page[@name='work_information']//field[@name='department_id']" position="attributes">
                    <attribute name="readonly">not can_manage_services</attribute>
                </xpath>

                <xpath expr="//page[@name='work_information']//field[@name='parent_id']" position="attributes">
                    <attribute name="readonly">not can_manage_services</attribute>
                </xpath>

                <xpath expr="//page[@name='work_information']//field[@name='job_title']" position="attributes">
                    <attribute name="readonly">not can_manage_services</attribute>
                </xpath>

                <xpath expr="//page[@name='work_information']//field[@name='address_id']" position="replace">
                    <field name="main_site_address_display" readonly="1"/>
                </xpath>

                <xpath expr="//page[@name='work_information']//field[@name='work_location_id']" position="replace">
                    <field name="main_site_id" string="Pracovisko" readonly="not can_manage_services" />
                    <field name="secondary_site_ids" widget="many2many_tags" readonly="not can_manage_services" />
                    <separator string="Týždenný rozvrh pracovísk"/>
                    <field
                        name="weekly_workplace_ids"
                        nolabel="1"
                        colspan="2"
                        readonly="not tenenet_can_edit_self_employee_fields"
                        context="{'default_employee_id': id}"
                    >
                        <list string="Týždenný rozvrh pracovísk" editable="bottom">
                            <field name="weekday"/>
                            <field name="time_from" widget="float_time"/>
                            <field name="time_to" widget="float_time"/>
                            <field
                                name="site_id"
                                domain="[('id', 'in', parent.tenenet_weekly_site_domain_ids), ('site_type', 'in', ['prevadzka', 'centrum'])]"
                            />
                        </list>
                        <form string="Týždenný rozvrh pracovísk">
                            <sheet>
                                <group>
                                    <field name="employee_id" invisible="1"/>
                                    <field name="weekday"/>
                                    <field name="time_from" widget="float_time"/>
                                    <field name="time_to" widget="float_time"/>
                                    <field
                                        name="site_id"
                                        domain="[('id', 'in', parent.tenenet_weekly_site_domain_ids), ('site_type', 'in', ['prevadzka', 'centrum'])]"
                                    />
                                </group>
                            </sheet>
                        </form>
                    </field>
                </xpath>

                <xpath
                    expr="//group[field[@name='monday_location_id'] and field[@name='tuesday_location_id'] and field[@name='wednesday_location_id'] and field[@name='thursday_location_id'] and field[@name='friday_location_id'] and field[@name='saturday_location_id'] and field[@name='sunday_location_id']]"
                    position="replace"
                />

                <xpath expr="//notebook" position="inside">
                    <page string="TENENET">
                        <group>
                            <group string="Profil">
                                <field name="work_ratio" string="Úväzok (%)" readonly="not can_manage_services" />
                                <field name="experience_years_total" readonly="not can_manage_services" />
                            </group>
                            <group string="Mzdové nastavenie">
                                <field name="monthly_gross_salary_target" string="Mesačný cieľ CCP" readonly="not can_manage_services" />
                                <field name="monthly_gross_salary_target_hm" readonly="1" string="Mesačný cieľ HM (brutto)" />
                                <field name="hourly_rate" readonly="1" string="Reziduálna hodinová sadzba CCP" />
                            </group>
                        </group>
                        <group>
                            <group string="Kapacita a alokácia">
                                <field
                                    name="tenenet_allocation_ratio_total"
                                    readonly="1"
                                    string="Projektový podiel spolu (%)"
                                />
                                <field name="tenenet_free_ratio" readonly="1" />
                                <field
                                    name="tenenet_availability_state"
                                    readonly="1"
                                    widget="badge"
                                />
                            </group>
                        </group>
                        <group string="Platové usmernenie">
                            <field name="salary_guidance_html" nolabel="1" widget="html" class="o_tenenet_salary_guidance_field"/>
                        </group>
                        <div class="o_tenenet_employee_assignments mt-4">
                            <div class="o_form_label mb-2">
                                Priradenia k projektom
                            </div>
                            <field
                                name="assignment_ids"
                                nolabel="1"
                                readonly="1"
                                colspan="2"
                                domain="[('is_current', '=', True)]"
                                class="o_tenenet_employee_assignments_field"
                            >
                                <list
                                    string="Priradenia k projektom"
                                    class="o_tenenet_employee_assignments_list"
                                >
                                    <field name="project_id" />
                                    <field
                                        name="allocation_ratio"
                                        string="Úväzok (%)"
                                    />
                                    <field
                                        name="date_start"
                                        string="Začiatok"
                                    />
                                    <field
                                        name="date_end"
                                        string="Koniec"
                                    />
                                    <field
                                        name="wage_hm"
                                        string="HM/brutto / hod."
                                    />
                                    <field
                                        name="wage_ccp"
                                        string="CCP / hod."
                                    />
                                    <button
                                        name="action_open_timesheet_matrix_current_year"
                                        type="object"
                                        string="Otvoriť maticu"
                                        class="btn-link"
                                    />
                                </list>
                            </field>
                        </div>
                    </page>
                    <page string="Firemný majetok">
                        <group>
                            <group>
                                <field name="asset_total_value" readonly="1"/>
                            </group>
                        </group>
                        <button
                            name="%(tenenet_projects.action_tenenet_employee_asset_handover_wizard)d"
                            type="action"
                            string="Pridať majetok"
                            class="btn-primary"
                            context="{'default_employee_id': id}"
                            invisible="not can_manage_services"
                        />
                        <button
                            name="action_send_unsigned_assets_for_signature"
                            type="object"
                            string="Odoslať majetok na podpis"
                            class="btn-secondary"
                            invisible="not can_manage_services"
                        />
                        <separator string="Majetok"/>
                        <field
                            name="asset_ids"
                            nolabel="1"
                            context="{'default_employee_id': id}"
                            colspan="2"
                            readonly="not can_manage_services"
                        >
                            <list string="Firemný majetok" editable="bottom">
                                <field name="asset_type_id"/>
                                <field name="serial_number"/>
                                <field name="handover_date"/>
                                <field name="currency_id" column_invisible="1"/>
                                <field name="cost" optional="show"/>
                                <field name="sign_state" widget="badge" optional="show"/>
                                <field name="sign_request_id" optional="hide"/>
                                <field name="note" optional="show"/>
                                <field name="active"/>
                            </list>
                            <form string="Položka majetku">
                                <sheet>
                                    <group>
                                        <field name="employee_id" invisible="1"/>
                                        <field name="asset_type_id"/>
                                        <field name="serial_number"/>
                                        <field name="handover_date"/>
                                        <field name="handover_id" readonly="1"/>
                                        <field name="sign_request_id" readonly="1"/>
                                        <field name="sign_state" readonly="1" widget="badge"/>
                                        <field name="currency_id"/>
                                        <field name="cost"/>
                                        <field name="active"/>
                                    </group>
                                    <group>
                                        <field name="note"/>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                        <separator string="Kľúče"/>
                        <field
                            name="site_key_ids"
                            nolabel="1"
                            context="{'default_employee_id': id}"
                            colspan="2"
                            readonly="not can_manage_services"
                        >
                            <list string="Kľúče" editable="bottom">
                                <field name="site_id" domain="[('site_type', 'in', ['prevadzka', 'centrum'])]"/>
                                <field name="active"/>
                            </list>
                            <form string="Kľúč">
                                <sheet>
                                    <group>
                                        <field name="employee_id" invisible="1"/>
                                        <field name="site_id" domain="[('site_type', 'in', ['prevadzka', 'centrum'])]"/>
                                        <field name="active"/>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </page>
                </xpath>

                <xpath expr="//page[@name='personal_information']/group/group[field[@name='private_email']]" position="inside">
                    <field name="can_view_private_phone" invisible="1" />
                    <field
                        name="work_phone"
                        widget="phone"
                        string="Pracovný telefón"
                    />
                </xpath>

                <xpath expr="//page[@name='personal_information']//field[@name='private_phone']" position="replace">
                    <field
                        name="private_phone"
                        widget="phone"
                        string="Súkromný telefón"
                        invisible="not can_view_private_phone"
                    />
                </xpath>

                <xpath
                    expr="//page[@name='resume']//div[@id='o_employee_left']"
                    position="inside"
                >
                    <group string="Bio">
                        <field
                            name="bio"
                            nolabel="1"
                            widget="text"
                            placeholder="Predstavte skúsenosti, zameranie a oblasť práce zamestnanca."
                            class="o_tenenet_resume_text"
                            readonly="not tenenet_can_edit_self_employee_fields"
                        />
                    </group>
                    <group string="Ročné hodnotenia">
                        <field
                            name="evaluation_ids"
                            nolabel="1"
                            context="{'default_employee_id': id}"
                        >
                            <kanban class="o_kanban_mobile">
                                <field name="year_display"/>
                                <field name="manager_name"/>
                                <field name="visible_to_employee"/>
                                <field name="summary"/>
                                <templates>
                                    <t t-name="card">
                                        <div class="o_tenenet_eval_card">
                                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                                <strong><field name="year_display"/></strong>
                                                <span t-if="record.visible_to_employee.raw_value" class="badge text-bg-success">
                                                    Zdieľané
                                                </span>
                                                <span t-else="" class="badge text-bg-secondary">
                                                    Interné
                                                </span>
                                            </div>
                                            <div class="text-muted small mb-2">
                                                <field name="manager_name"/>
                                            </div>
                                            <div t-if="record.summary.raw_value" class="text-wrap">
                                                <field name="summary"/>
                                            </div>
                                            <div t-else="" class="text-muted">
                                                Bez celkového zhodnotenia.
                                            </div>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                            <form string="Ročné hodnotenie">
                                <sheet>
                                        <group>
                                            <group>
                                                <field name="employee_id" invisible="1"/>
                                                <field name="year_display"/>
                                                <field name="manager_id"/>
                                                <field name="author_user_id" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="visible_to_employee"/>
                                                <field name="active"/>
                                            </group>
                                        </group>
                                        <separator string="Obsah hodnotenia"/>
                                        <div class="o_tenenet_eval_form_stack">
                                            <div class="o_tenenet_eval_form_block">
                                                <label for="summary" string="Celkové zhodnotenie"/>
                                                <field name="summary" nolabel="1"/>
                                            </div>
                                            <div class="o_tenenet_eval_form_block">
                                                <label for="strengths" string="Silné stránky"/>
                                                <field name="strengths" nolabel="1"/>
                                            </div>
                                            <div class="o_tenenet_eval_form_block">
                                                <label for="goals" string="Ciele na ďalší rok"/>
                                                <field name="goals" nolabel="1"/>
                                            </div>
                                            <div class="o_tenenet_eval_form_block">
                                                <label for="recommendations" string="Odporúčania"/>
                                                <field name="recommendations" nolabel="1"/>
                                            </div>
                                        </div>
                                    </sheet>
                                </form>
                        </field>
                    </group>
                    <group string="TENENET školenia">
                        <field
                            name="training_ids"
                            nolabel="1"
                            context="{'default_employee_id': id}"
                        >
                            <list string="Školenia">
                                <field name="name" />
                                <field name="training_type" />
                                <field name="provider" />
                                <field name="date_from" />
                                <field name="date_to" />
                                <field name="certificate_date" />
                                <field name="active" />
                            </list>
                            <form string="Školenie">
                                <sheet>
                                    <group>
                                        <group>
                                            <field
                                                name="employee_id"
                                                invisible="1"
                                            />
                                            <field name="name" />
                                            <field name="training_type" />
                                            <field name="provider" />
                                        </group>
                                        <group>
                                            <field name="date_from" />
                                            <field name="date_to" />
                                            <field name="certificate_date" />
                                            <field name="active" />
                                        </group>
                                    </group>
                                    <group>
                                        <field name="notes" />
                                    </group>
                                </sheet>
                                <chatter
                                    open_attachments="True"
                                    reload_on_attachment="True"
                                />
                            </form>
                        </field>
                    </group>
                </xpath>

                <xpath expr="//field[@name='resume_line_ids']" position="attributes">
                    <attribute name="readonly">not tenenet_can_edit_self_employee_fields</attribute>
                </xpath>

                <xpath expr="//field[@name='current_employee_skill_ids']" position="attributes">
                    <attribute name="readonly">not can_manage_services</attribute>
                </xpath>

                <xpath expr="//field[@name='certification_ids']" position="attributes">
                    <attribute name="readonly">not can_manage_services</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_hr_employee_public_form_tenenet" model="ir.ui.view">
            <field name="name">hr.employee.public.form.tenenet</field>
            <field name="model">hr.employee.public</field>
            <field name="inherit_id" ref="hr.hr_employee_public_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <field name="tenenet_can_open_private_employee_card" invisible="1"/>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button
                        name="action_tenenet_open_private_employee_card"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-id-card-o"
                        invisible="not tenenet_can_open_private_employee_card"
                    >
                        <div class="o_stat_info">
                            <span class="o_stat_text">Celá karta</span>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//div[hasclass('oe_title')]" position="after">
                    <div class="mt-3" invisible="not tenenet_can_open_private_employee_card">
                        <button
                            name="action_tenenet_open_private_employee_card"
                            type="object"
                            string="Otvoriť celú kartu"
                            class="btn-primary"
                            icon="fa-id-card-o"
                        />
                    </div>
                </xpath>
                <xpath expr="//page[@name='work_information']//div[@id='o_work_employee_main']/group[1]" position="inside">
                    <field name="all_job_names" string="Pozície"/>
                    <field name="all_site_names" string="Miesta práce"/>
                </xpath>
                <xpath expr="//page[@name='work_information']//field[@name='address_id']" position="replace">
                    <field name="main_site_address_display" readonly="1"/>
                </xpath>
                <xpath expr="//page[@name='work_information']//field[@name='work_location_id']" position="replace">
                    <field name="main_site_id" string="Pracovisko" readonly="1"/>
                    <field name="secondary_site_ids" widget="many2many_tags" readonly="1"/>
                    <separator string="Týždenný rozvrh pracovísk"/>
                    <field name="weekly_workplace_ids" nolabel="1" colspan="2" readonly="1">
                        <list string="Týždenný rozvrh pracovísk" create="False" edit="False" delete="False">
                            <field name="weekday"/>
                            <field name="time_from" widget="float_time"/>
                            <field name="time_to" widget="float_time"/>
                            <field name="site_id"/>
                        </list>
                        <form string="Týždenný rozvrh pracovísk" create="False" edit="False" delete="False">
                            <sheet>
                                <group>
                                    <field name="employee_id" invisible="1"/>
                                    <field name="weekday" readonly="1"/>
                                    <field name="time_from" widget="float_time" readonly="1"/>
                                    <field name="time_to" widget="float_time" readonly="1"/>
                                    <field name="site_id" readonly="1"/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </xpath>
                <xpath expr="//page[@name='work_information']" position="after">
                    <page string="Služby">
                        <separator
                            string="Služby, ktoré zamestnanec poskytuje"
                        />
                        <field name="service_ids" nolabel="1" colspan="2">
                            <list string="Služby">
                                <field name="name" string="Služba" />
                                <field name="delivery_online" />
                                <field name="delivery_in_person" />
                                <field name="active" />
                            </list>
                            <form string="Služba">
                                <sheet>
                                    <group col="1">
                                        <field
                                            name="name"
                                            string="Služba"
                                            readonly="1"
                                        />
                                        <field name="delivery_online" readonly="1" />
                                        <field name="delivery_in_person" readonly="1" />
                                        <field name="active" readonly="1" />
                                    </group>
                                    <group>
                                        <field
                                            name="description"
                                            readonly="1"
                                        />
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </page>
                </xpath>
                <xpath expr="//page[@name='resume']" position="replace">
                    <page name="resume" string="Resume">
                        <div class="row">
                            <div class="col-lg-7 d-flex flex-column">
                                <group string="Bio">
                                    <field name="bio" nolabel="1" readonly="1" widget="text" class="o_tenenet_resume_text"/>
                                </group>
                            </div>
                            <div class="col-lg-5 px-0 ps-lg-5 pe-lg-0">
                                <group string="Znalosti">
                                    <field name="employee_id" invisible="1"/>
                                    <field mode="list" nolabel="1" name="current_employee_skill_ids" widget="skills_one2many" readonly="1">
                                        <list
                                            no_open="1"
                                            create="False"
                                            edit="False"
                                            delete="False"
                                            decoration-muted="valid_to and valid_to &lt; context_today().strftime('%Y-%m-%d')"
                                            decoration-danger="valid_to and valid_to &lt;= (context_today() + relativedelta(days=7)).strftime('%Y-%m-%d') and valid_to &gt; context_today().strftime('%Y-%m-%d')"
                                            decoration-warning="valid_to and valid_to &lt;= (context_today() + relativedelta(months=3)).strftime('%Y-%m-%d') and valid_to &gt; (context_today() + relativedelta(days=7)).strftime('%Y-%m-%d')">
                                            <field name="skill_type_id" optional="hidden"/>
                                            <field name="skill_id"/>
                                            <field name="skill_level_id"/>
                                            <field name="level_progress" widget="progressbar"/>
                                            <field name="valid_to" column_invisible="1"/>
                                        </list>
                                    </field>
                                </group>
                            </div>
                        </div>
                    </page>
                </xpath>
                <xpath expr="//page[@name='certification']" position="replace"/>
            </field>
        </record>

        <record id="view_hr_employee_public_list_open_card_tenenet" model="ir.ui.view">
            <field name="name">hr.employee.public.list.open.card.tenenet</field>
            <field name="model">hr.employee.public</field>
            <field name="inherit_id" ref="hr.hr_employee_public_view_tree" />
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="action">action_tenenet_open_employee_card</attribute>
                    <attribute name="type">object</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_hr_employee_public_kanban_open_card_tenenet" model="ir.ui.view">
            <field name="name">hr.employee.public.kanban.open.card.tenenet</field>
            <field name="model">hr.employee.public</field>
            <field name="inherit_id" ref="hr.hr_employee_public_view_kanban" />
            <field name="arch" type="xml">
                <xpath expr="//kanban" position="attributes">
                    <attribute name="action">action_tenenet_open_employee_card</attribute>
                    <attribute name="type">object</attribute>
                </xpath>
            </field>
        </record>

        <record id="action_tenenet_employees" model="ir.actions.act_window">
            <field name="name">Zamestnanci</field>
            <field name="res_model">hr.employee</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_hr_employee_tenenet_list" />
            <field
                name="search_view_id"
                ref="view_hr_employee_tenenet_search"
            />
        </record>
    </data>
</odoo>
