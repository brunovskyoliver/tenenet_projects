<odoo>
    <data>
        <record id="view_tenenet_project_timesheet_list" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.list</field>
            <field name="model">tenenet.project.timesheet</field>
            <field name="arch" type="xml">
                <list string="Timesheety" editable="bottom"
                      decoration-warning="hours_total == 0">
                    <field name="employee_id" optional="show"/>
                    <field name="project_id" optional="show"/>
                    <field name="period"/>
                    <field name="hours_pp"/>
                    <field name="hours_np"/>
                    <field name="hours_travel" optional="hide"/>
                    <field name="hours_training" optional="hide"/>
                    <field name="hours_ambulance" optional="hide"/>
                    <field name="hours_international" optional="hide"/>
                    <field name="hours_project_total" readonly="1"/>
                    <field name="hours_vacation" optional="hide"/>
                    <field name="hours_sick" optional="hide"/>
                    <field name="hours_doctor" optional="hide"/>
                    <field name="hours_holidays" optional="hide"/>
                    <field name="hours_leave_total" readonly="1" optional="hide"/>
                    <field name="hours_total" readonly="1"/>
                    <field name="wage_hm" optional="hide" readonly="1"/>
                    <field name="wage_ccp" optional="hide" readonly="1"/>
                    <field name="gross_salary" readonly="1" optional="show"/>
                    <field name="total_labor_cost" readonly="1" optional="show"/>
                    <field name="currency_id" column_invisible="1"/>
                    <field name="leave_auto_synced" optional="hide" readonly="1"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_form" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.form</field>
            <field name="model">tenenet.project.timesheet</field>
            <field name="arch" type="xml">
                <form string="Timesheet zamestnanca">
                    <sheet>
                        <group>
                            <group>
                                <field name="assignment_id"/>
                                <field name="employee_id" readonly="1"/>
                                <field name="project_id" readonly="1"/>
                                <field name="period"/>
                                <field name="leave_auto_synced" readonly="1"/>
                            </group>
                            <group>
                                <field name="wage_hm" readonly="1"/>
                                <field name="wage_ccp" readonly="1"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Riadky hodín">
                                <field name="line_ids">
                                    <list string="Riadky hodín" editable="bottom">
                                        <field name="scope" readonly="1" optional="show"/>
                                        <field name="hour_type"/>
                                        <field name="hours"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Súhrn">
                                <group>
                                    <group string="Projektové hodiny">
                                        <field name="hours_pp"/>
                                        <field name="hours_np"/>
                                        <field name="hours_travel"/>
                                        <field name="hours_training"/>
                                        <field name="hours_ambulance"/>
                                        <field name="hours_international"/>
                                        <field name="hours_project_total" readonly="1"/>
                                    </group>
                                    <group string="Absencie">
                                        <field name="hours_vacation"/>
                                        <field name="hours_sick"/>
                                        <field name="hours_doctor"/>
                                        <field name="hours_holidays"/>
                                        <field name="hours_leave_total" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Náklady">
                                <group>
                                    <field name="hours_total" readonly="1"/>
                                    <field name="gross_salary" readonly="1"/>
                                    <field name="deductions" readonly="1"/>
                                    <field name="total_labor_cost" readonly="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_search" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.search</field>
            <field name="model">tenenet.project.timesheet</field>
            <field name="arch" type="xml">
                <search string="Timesheety">
                    <field name="employee_id"/>
                    <field name="project_id"/>
                    <field name="period"/>
                    <filter string="Zamestnanec" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Projekt" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Obdobie" name="group_period" context="{'group_by': 'period:month'}"/>
                </search>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_pivot" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.pivot</field>
            <field name="model">tenenet.project.timesheet</field>
            <field name="arch" type="xml">
                <pivot string="Timesheety">
                    <field name="employee_id" type="row"/>
                    <field name="project_id" type="row"/>
                    <field name="period" type="col" interval="month"/>
                    <field name="hours_total" type="measure"/>
                    <field name="total_labor_cost" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_graph" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.graph</field>
            <field name="model">tenenet.project.timesheet</field>
            <field name="arch" type="xml">
                <graph string="Timesheety podľa projektu" type="bar">
                    <field name="project_id" type="row"/>
                    <field name="hours_project_total" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="action_tenenet_project_timesheet" model="ir.actions.act_window">
            <field name="name">Timesheety</field>
            <field name="res_model">tenenet.project.timesheet</field>
            <field name="view_mode">list,form,pivot,graph</field>
        </record>

        <record id="view_tenenet_project_timesheet_line_list" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.line.list</field>
            <field name="model">tenenet.project.timesheet.line</field>
            <field name="arch" type="xml">
                <list string="Mesačné riadky hodín" editable="bottom">
                    <field name="timesheet_id"/>
                    <field name="project_id" optional="show"/>
                    <field name="employee_id" optional="show"/>
                    <field name="period"/>
                    <field name="scope" readonly="1" optional="show"/>
                    <field name="hour_type"/>
                    <field name="hours"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_line_form" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.line.form</field>
            <field name="model">tenenet.project.timesheet.line</field>
            <field name="arch" type="xml">
                <form string="Riadok timesheetu">
                    <sheet>
                        <group>
                            <group>
                                <field name="timesheet_id"/>
                                <field name="project_id" readonly="1"/>
                                <field name="employee_id" readonly="1"/>
                                <field name="period" readonly="1"/>
                            </group>
                            <group>
                                <field name="scope" readonly="1"/>
                                <field name="hour_type"/>
                                <field name="hours"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_line_search" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.line.search</field>
            <field name="model">tenenet.project.timesheet.line</field>
            <field name="arch" type="xml">
                <search string="Mesačné riadky hodín">
                    <field name="project_id"/>
                    <field name="employee_id"/>
                    <field name="period"/>
                    <field name="hour_type"/>
                    <filter string="Projekt" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Zamestnanec" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Kategória" name="group_hour_type" context="{'group_by': 'hour_type'}"/>
                    <filter string="Obdobie" name="group_period" context="{'group_by': 'period:month'}"/>
                </search>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_line_pivot" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.line.pivot</field>
            <field name="model">tenenet.project.timesheet.line</field>
            <field name="arch" type="xml">
                <pivot string="Mesačná mriežka hodín">
                    <field name="project_id" type="row"/>
                    <field name="employee_id" type="row"/>
                    <field name="hour_type" type="row"/>
                    <field name="period" type="col" interval="month"/>
                    <field name="hours" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="action_tenenet_project_timesheet_line" model="ir.actions.act_window">
            <field name="name">Mesačná mriežka hodín</field>
            <field name="res_model">tenenet.project.timesheet.line</field>
            <field name="view_mode">list,pivot,form</field>
            <field name="search_view_id" ref="view_tenenet_project_timesheet_line_search"/>
        </record>
    </data>
</odoo>
