<odoo>
    <data>
        <record id="view_tenenet_utilization_list" model="ir.ui.view">
            <field name="name">tenenet.utilization.list</field>
            <field name="model">tenenet.utilization</field>
            <field name="arch" type="xml">
                <list string="Vyťaženosť">
                    <field name="employee_id"/>
                    <field name="period"/>
                    <field name="capacity_hours"/>
                    <field name="hours_project_total"/>
                    <field name="utilization_rate" widget="progressbar"/>
                    <field name="utilization_status" widget="badge"/>
                    <field name="non_project_rate" widget="progressbar" optional="hide"/>
                    <field name="non_project_status" widget="badge" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_utilization_form" model="ir.ui.view">
            <field name="name">tenenet.utilization.form</field>
            <field name="model">tenenet.utilization</field>
            <field name="arch" type="xml">
                <form string="Vyťaženosť">
                    <sheet>
                        <group>
                            <group>
                                <field name="employee_id"/>
                                <field name="manager_id"/>
                                <field name="period"/>
                            </group>
                            <group>
                                <field name="work_ratio"/>
                                <field name="capacity_hours"/>
                                <field name="hours_diff" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Projektové hodiny">
                                <group>
                                    <field name="hours_pp"/>
                                    <field name="hours_np"/>
                                    <field name="hours_travel"/>
                                    <field name="hours_training"/>
                                    <field name="hours_ambulance"/>
                                    <field name="hours_international"/>
                                    <field name="hours_project_total" readonly="1"/>
                                </group>
                            </page>
                            <page string="Neprojektové hodiny">
                                <group>
                                    <field name="hours_vacation"/>
                                    <field name="hours_doctor"/>
                                    <field name="hours_sick"/>
                                    <field name="hours_ballast"/>
                                    <field name="hours_non_project_total" readonly="1"/>
                                </group>
                            </page>
                            <page string="KPI">
                                <group>
                                    <group>
                                        <field name="utilization_rate" widget="progressbar" readonly="1"/>
                                        <field name="utilization_status" widget="badge" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="non_project_rate" widget="progressbar" readonly="1"/>
                                        <field name="non_project_status" widget="badge" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_utilization_search" model="ir.ui.view">
            <field name="name">tenenet.utilization.search</field>
            <field name="model">tenenet.utilization</field>
            <field name="arch" type="xml">
                <search string="Vyťaženosť">
                    <field name="employee_id"/>
                    <field name="manager_id"/>
                    <field name="period"/>
                    <filter string="Vyťaženosť OK" name="utilization_ok" domain="[('utilization_status', '=', 'ok')]"/>
                    <filter string="Vyťaženosť upozornenie" name="utilization_warning" domain="[('utilization_status', '=', 'warning')]"/>
                    <filter string="Neprojektové OK" name="non_project_ok" domain="[('non_project_status', '=', 'ok')]"/>
                    <filter string="Neprojektové upozornenie" name="non_project_warning" domain="[('non_project_status', '=', 'warning')]"/>
                    <filter string="Zamestnanec" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Obdobie" name="group_period" context="{'group_by': 'period'}"/>
                    <filter string="Manažér" name="group_manager" context="{'group_by': 'manager_id'}"/>
                </search>
            </field>
        </record>

        <record id="view_tenenet_utilization_pivot" model="ir.ui.view">
            <field name="name">tenenet.utilization.pivot</field>
            <field name="model">tenenet.utilization</field>
            <field name="arch" type="xml">
                <pivot string="Vyťaženosť">
                    <field name="employee_id" type="row"/>
                    <field name="period" type="col" interval="month"/>
                    <field name="utilization_rate" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="view_tenenet_utilization_graph" model="ir.ui.view">
            <field name="name">tenenet.utilization.graph</field>
            <field name="model">tenenet.utilization</field>
            <field name="arch" type="xml">
                <graph string="Vyťaženosť podľa zamestnanca" type="bar">
                    <field name="employee_id" type="row"/>
                    <field name="utilization_rate" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="action_tenenet_utilization" model="ir.actions.act_window">
            <field name="name">Vyťaženosť</field>
            <field name="res_model">tenenet.utilization</field>
            <field name="view_mode">list,form,pivot,graph</field>
        </record>
    </data>
</odoo>
