<odoo>
    <data>
        <record id="view_tenenet_helpdesk_mass_ticket_wizard_form" model="ir.ui.view">
            <field name="name">tenenet.helpdesk.mass.ticket.wizard.form</field>
            <field name="model">tenenet.helpdesk.mass.ticket.wizard</field>
            <field name="arch" type="xml">
                <form string="Hromadný ticket">
                    <sheet>
                        <group>
                            <field name="team_id"/>
                            <field name="name" placeholder="Krátky názov úlohy"/>
                            <field name="target_type" widget="radio"/>
                        </group>
                        <group>
                            <field name="company_id" invisible="target_type != 'company'" required="target_type == 'company'"/>
                            <field name="department_id" invisible="target_type != 'department'" required="target_type == 'department'"/>
                            <field name="organizational_unit_id" invisible="target_type != 'organizational_unit'" required="target_type == 'organizational_unit'"/>
                            <field name="project_id" invisible="target_type != 'project'" required="target_type == 'project'"/>
                        </group>
                        <group>
                            <field name="priority" widget="priority"/>
                            <field name="date_deadline"/>
                            <field name="employee_count" readonly="1"/>
                        </group>
                        <notebook>
                            <page name="employees" string="Zamestnanci">
                                <field name="employee_ids" widget="many2many_avatar_employee" readonly="1"/>
                            </page>
                            <page name="description" string="Popis">
                                <field name="description" type="html" options="{'collaborative': true, 'resizable': false}"/>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_create_ticket" string="Vytvoriť ticket" type="object" class="btn-primary"/>
                        <button string="Zrušiť" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_tenenet_helpdesk_mass_ticket_wizard" model="ir.actions.act_window">
            <field name="name">Hromadný ticket</field>
            <field name="res_model">tenenet.helpdesk.mass.ticket.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_tenenet_helpdesk_mass_ticket_wizard_form"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
