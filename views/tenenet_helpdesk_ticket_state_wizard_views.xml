<odoo>
    <data>
        <record id="view_tenenet_helpdesk_ticket_state_wizard_form" model="ir.ui.view">
            <field name="name">tenenet.helpdesk.ticket.state.wizard.form</field>
            <field name="model">tenenet.helpdesk.ticket.state.wizard</field>
            <field name="arch" type="xml">
                <form string="TENENET Helpdesk">
                    <group>
                        <field name="ticket_id" invisible="1"/>
                        <field name="request_type"/>
                        <field name="allowed_user_ids" invisible="1"/>
                        <field
                            name="user_id"
                            widget="many2one_avatar_user"
                            domain="[('id', 'in', allowed_user_ids)]"
                        />
                    </group>
                    <footer>
                        <button name="action_confirm" string="Potvrdiť" type="object" class="btn-primary"/>
                        <button string="Zrušiť" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
