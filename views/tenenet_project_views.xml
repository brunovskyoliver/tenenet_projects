<odoo>
    <data>
        <record id="view_tenenet_project_list" model="ir.ui.view">
            <field name="name">tenenet.project.list</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <list string="Projekty">
                    <field name="year"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="program_id"/>
                    <field name="donor_id"/>
                    <field name="budget_total"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="semaphore" widget="badge"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_project_form" model="ir.ui.view">
            <field name="name">tenenet.project.form</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <form string="Projekt">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="description"/>
                                <field name="year"/>
                                <field name="active"/>
                                <field name="semaphore"/>
                            </group>
                            <group>
                                <field name="program_id"/>
                                <field name="donor_id"/>
                                <field name="recipient_partner_id"/>
                                <field name="contract_number"/>
                                <field name="duration" readonly="1"/>
                                <field name="date_contract"/>
                                <field name="call_info"/>
                                <field name="partner_id"/>
                                <field name="submission_info"/>
                                <field name="portal"/>
                                <field name="sustainability"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Termíny">
                                <group>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                </group>
                            </page>
                            <page string="Riadenie">
                                <group>
                                    <field name="odborny_garant_id"/>
                                    <field name="project_manager_id"/>
                                </group>
                            </page>
                            <page string="Financie">
                                <group>
                                    <group>
                                        <field name="currency_id"/>
                                        <field name="budget_total"/>
                                        <field name="amount_contracted"/>
                                        <field name="amount_contracted_with_partners"/>
                                    </group>
                                    <group>
                                        <field name="active_year_from" readonly="1"/>
                                        <field name="active_year_to" readonly="1"/>
                                        <field name="received_total" readonly="1"/>
                                        <field name="budget_diff" readonly="1"/>
                                    </group>
                                </group>
                                <group string="Prijaté podľa rokov">
                                    <field name="receipt_line_ids">
                                        <list string="Prijaté podľa rokov" create="0" delete="0">
                                            <field name="year" readonly="1"/>
                                            <field name="amount"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page string="Priradenia zamestnancov">
                                <field name="assignment_ids">
                                    <list string="Priradenia zamestnancov" editable="bottom">
                                        <field name="employee_id"/>
                                        <field name="date_start"/>
                                        <field name="date_end"/>
                                        <field name="wage_hm"/>
                                        <field name="wage_ccp"/>
                                        <field name="active"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Timesheety">
                                <group>
                                    <button name="action_open_timesheet_month_matrix"
                                            type="object"
                                            string="Otvoriť mesačnú maticu"
                                            class="oe_highlight"/>
                                </group>
                                <field name="timesheet_ids">
                                    <list string="Timesheety" editable="bottom"
                                          decoration-warning="hours_total == 0">
                                        <field name="assignment_id"/>
                                        <field name="employee_id" readonly="1"/>
                                        <field name="period"/>
                                        <field name="hours_pp"/>
                                        <field name="hours_np"/>
                                        <field name="hours_travel" optional="hide"/>
                                        <field name="hours_training" optional="hide"/>
                                        <field name="hours_ambulance" optional="hide"/>
                                        <field name="hours_international" optional="hide"/>
                                        <field name="hours_project_total" readonly="1"/>
                                        <field name="hours_vacation" optional="hide"/>
                                        <field name="hours_sick" optional="hide"/>
                                        <field name="hours_doctor" optional="hide"/>
                                        <field name="hours_holidays" optional="hide"/>
                                        <field name="hours_total" readonly="1"/>
                                        <field name="gross_salary" readonly="1" optional="show"/>
                                        <field name="total_labor_cost" readonly="1" optional="show"/>
                                        <field name="currency_id" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Pravidlá dovolenky">
                                <field name="leave_rule_ids">
                                    <list string="Pravidlá dovolenky" editable="bottom">
                                        <field name="leave_type_id"/>
                                        <field name="included"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Kontakty a zúčtovanie">
                                <group>
                                    <field name="donor_contact" readonly="1"/>
                                    <field name="partner_contact" readonly="1"/>
                                    <field name="settlement_info"/>
                                    <field name="application_notes"/>
                                </group>
                            </page>
                            <page string="Poznámky">
                                <group>
                                    <field name="comments"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_project_search" model="ir.ui.view">
            <field name="name">tenenet.project.search</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <search string="Projekty">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="program_id"/>
                    <field name="donor_id"/>
                    <filter string="Aktívne" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Program" name="group_program" context="{'group_by': 'program_id'}"/>
                    <filter string="Rok" name="group_year" context="{'group_by': 'year'}"/>
                    <filter string="Donor" name="group_donor" context="{'group_by': 'donor_id'}"/>
                </search>
            </field>
        </record>

        <record id="view_tenenet_project_kanban" model="ir.ui.view">
            <field name="name">tenenet.project.kanban</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <kanban default_order="year desc, name">
                    <field name="semaphore"/>
                    <field name="odborny_garant_id"/>
                    <field name="project_manager_id"/>
                    <field name="budget_total"/>
                    <field name="currency_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <template>
                        <t t-name="tenenet_project_kanban_card">
                            <div class="oe_kanban_card oe_kanban_global_click p-3">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="text-muted small" t-out="record.code.value"/>
                                    <t t-if="record.semaphore.raw_value">
                                        <span t-attf-class="badge #{{'green':'bg-success','yellow':'bg-warning','red':'bg-danger'}[record.semaphore.raw_value]}">&amp;nbsp;</span>
                                    </t>
                                </div>
                                <strong class="d-block mb-2" t-out="record.name.value"/>
                                <div class="small text-muted">
                                    <span>Garant: </span><span t-out="record.odborny_garant_id.value or '—'"/>
                                </div>
                                <div class="small text-muted mb-2">
                                    <span>PM: </span><span t-out="record.project_manager_id.value or '—'"/>
                                </div>
                                <div class="d-flex justify-content-between small">
                                    <field name="budget_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <span>
                                        <t t-out="record.date_start.value"/> – <t t-out="record.date_end.value"/>
                                    </span>
                                </div>
                            </div>
                        </t>
                    </template>
                </kanban>
            </field>
        </record>

        <record id="action_tenenet_project" model="ir.actions.act_window">
            <field name="name">Projekty</field>
            <field name="res_model">tenenet.project</field>
            <field name="view_mode">kanban,list,form</field>
        </record>

        <record id="action_tenenet_garant_projects" model="ir.actions.act_window">
            <field name="name">Moje projekty (Garant/PM)</field>
            <field name="res_model">tenenet.project</field>
            <field name="view_mode">kanban,list</field>
            <field name="domain">[('active','=',True),'|',('odborny_garant_id.user_id','=',uid),('project_manager_id.user_id','=',uid)]</field>
        </record>
    </data>
</odoo>
