<odoo>
    <data>
        <record id="view_tenenet_project_list" model="ir.ui.view">
            <field name="name">tenenet.project.list</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <list string="Projekty" class="o_tenenet_project_list">
                    <field name="semaphore"
                           widget="badge"
                           decoration-success="semaphore == 'green'"
                           decoration-warning="semaphore == 'orange'"
                           decoration-danger="semaphore == 'red'"
                           class="o_tenenet_project_semaphore_dot"/>
                    <field name="name"/>
                    <field name="ui_program_ids" widget="many2many_tags"/>
                    <field name="donor_id"/>
                    <field name="budget_total"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_project_form" model="ir.ui.view">
            <field name="name">tenenet.project.form</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <form string="Projekt" class="o_tenenet_project_form">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="description"/>
                                <field name="active"/>
                                <field name="is_recurring_license_project"/>
                                <field name="recurring_clone_anchor_date"
                                       invisible="not is_recurring_license_project"/>
                                <field name="recurring_clone_interval_type"
                                       invisible="not is_recurring_license_project"/>
                                <field name="recurring_next_clone_date"
                                       readonly="1"
                                       invisible="not is_recurring_license_project"/>
                                <button name="action_test_recurring_clone"
                                        type="object"
                                        string="Test klonovania"
                                        class="btn btn-secondary"
                                        invisible="not id or not is_recurring_license_project"/>
                                <field name="semaphore"/>
                            </group>
                            <group>
                                <field name="ui_program_ids" widget="many2many_tags"/>
                                <field name="donor_id"/>
                                <field name="recipient_partner_id"/>
                                <field name="partner_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Termíny">
                                <group>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="duration" readonly="1"/>
                                </group>
                                <separator string="Míľniky"/>
                                <div class="mb-2">
                                    <button name="action_open_milestone_wizard"
                                            type="object"
                                            string="Pridať míľnik"
                                            class="btn btn-primary"
                                            invisible="not id or not can_manage_milestones"/>
                                </div>
                                <field name="milestone_ids" nolabel="1">
                                    <list string="Míľniky" create="0" delete="0" edit="0" no_open="1" default_order="date asc, sequence asc, id asc">
                                        <field name="date"/>
                                        <field name="name"/>
                                        <field name="note" optional="show"/>
                                        <field name="message_attachment_count" string="Prílohy" optional="show"/>
                                        <button name="action_open_edit_wizard"
                                                type="object"
                                                string="Upraviť"
                                                icon="fa-pencil"
                                                class="btn-link"
                                                column_invisible="not parent.can_manage_milestones"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Financie">
                                <group>
                                    <group>
                                        <field name="contract_number"/>
                                        <field name="date_contract"/>
                                    </group>
                                    <group>
                                        <field name="active_year_from" readonly="1"/>
                                        <field name="active_year_to" readonly="1"/>
                                        <field name="budget_total" readonly="1"/>
                                    </group>
                                </group>
                                <separator string="Finančný stav"/>
                                <div class="row g-3 mb-3">
                                    <div class="col-12 col-lg-4">
                                        <div class="border rounded-4 p-3 h-100 bg-light">
                                            <div class="text-muted small mb-2">Cashflow ku dnešku</div>
                                            <field name="finance_actual_vs_plan_to_date_state"
                                                   widget="badge"
                                                   nolabel="1"
                                                   class="mb-2"
                                                   decoration-success="finance_actual_vs_plan_to_date_state == 'plus'"
                                                   decoration-danger="finance_actual_vs_plan_to_date_state == 'minus'"
                                                   decoration-muted="finance_actual_vs_plan_to_date_state == 'neutral'"/>
                                            <div class="fw-semibold mb-1">Predikovaný cashflow mínus výdavky</div>
                                            <field name="finance_actual_vs_plan_to_date_amount"
                                                   nolabel="1"
                                                   readonly="1"/>
                                        </div>
                                    </div>
                                    <div class="col-12 col-lg-4">
                                        <div class="border rounded-4 p-3 h-100 bg-light">
                                            <div class="text-muted small mb-2">Aktuálny stav plánu</div>
                                            <field name="finance_cashflow_to_date_state"
                                                   widget="badge"
                                                   nolabel="1"
                                                   class="mb-2"
                                                   decoration-success="finance_cashflow_to_date_state == 'plus'"
                                                   decoration-danger="finance_cashflow_to_date_state == 'minus'"
                                                   decoration-muted="finance_cashflow_to_date_state == 'neutral'"/>
                                            <div class="fw-semibold mb-1">Stav podľa cashflow plánu</div>
                                            <field name="finance_cashflow_to_date_amount"
                                                   nolabel="1"
                                                   readonly="1"/>
                                        </div>
                                    </div>
                                    <div class="col-12 col-lg-4">
                                        <div class="border rounded-4 p-3 h-100 bg-light">
                                            <div class="text-muted small mb-2">Celkový výhľad</div>
                                            <field name="finance_forecast_total_state"
                                                   widget="badge"
                                                   nolabel="1"
                                                   class="mb-2"
                                                   decoration-success="finance_forecast_total_state == 'plus'"
                                                   decoration-danger="finance_forecast_total_state == 'minus'"
                                                   decoration-muted="finance_forecast_total_state == 'neutral'"/>
                                            <div class="fw-semibold mb-1">Zostatok financií projektu</div>
                                            <field name="finance_forecast_total_amount"
                                                   nolabel="1"
                                                   readonly="1"/>
                                        </div>
                                    </div>
                                </div>
                                <separator string="Prijaté prostriedky"/>
                                <div class="mb-2">
                                    <button name="action_open_receipt_wizard"
                                            type="object"
                                            string="Pridať príjem"
                                            class="btn btn-primary"
                                            invisible="not id"/>
                                    <button name="action_open_cashflow_gantt"
                                            type="object"
                                            string="Predikovaný cashflow"
                                            class="btn btn-secondary ms-2"
                                            invisible="not id or not receipt_line_ids"/>
                                </div>
                                <field name="receipt_line_ids" nolabel="1">
                                    <list string="Prijaté prostriedky" create="0" edit="0" delete="0"
                                          default_order="date_received desc">
                                        <field name="date_received"/>
                                        <field name="year" readonly="1" options="{'enable_formatting': False}"/>
                                        <field name="amount"/>
                                        <field name="note"/>
                                        <button name="action_open_cashflow_distribute_wizard"
                                                type="object"
                                                string="Distribuovať cashflow"
                                                class="btn-link"/>
                                        <button name="action_delete_with_reload"
                                                type="object"
                                                string="Odstrániť"
                                                icon="fa-trash"
                                                class="btn-link text-danger"/>
                                    </list>
                                </field>
                                <separator string="Cashflow planner" invisible="not id"/>
                                <field name="cashflow_planner_state"
                                       widget="tenenet_cashflow_planner"
                                       nolabel="1"
                                       readonly="1"
                                       invisible="not id"/>
                                <separator string="Mesačné porovnanie cashflow a výdavkov" invisible="not id"/>
                                <field name="finance_monthly_comparison_state"
                                       widget="tenenet_finance_comparison_chart"
                                       class="w-100"
                                       nolabel="1"
                                       invisible="not id"/>
                            </page>
                            <page string="Rozpočet">
                                <group>
                                    <group>
                                        <field name="budget_pausal_total" readonly="1"/>
                                        <field name="budget_labor_total" readonly="1"/>
                                        <field name="budget_other_total" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="allocation_summary_html" nolabel="1" widget="html" readonly="1"/>
                                    </group>
                                </group>
                                <div class="mb-2">
                                    <button name="action_open_budget_wizard"
                                            type="object"
                                            string="Pridať rozpočtovú položku"
                                            class="btn btn-primary"
                                            invisible="not id"/>
                                </div>
                                <separator string="Paušálne"/>
                                <field name="budget_pausal_line_ids">
                                    <list string="Paušálne položky" create="0" edit="0">
                                        <field name="year" options="{'enable_formatting': False}"/>
                                        <field name="program_id"/>
                                        <field name="name"/>
                                        <field name="amount"/>
                                        <field name="note" optional="show"/>
                                        <button name="action_open_planner"
                                                type="object"
                                                string="Planner"
                                                class="btn-link"/>
                                    </list>
                                </field>
                                <separator string="Mzdové"/>
                                <field name="budget_labor_line_ids">
                                    <list string="Mzdové položky" create="0" edit="0">
                                        <field name="year" options="{'enable_formatting': False}"/>
                                        <field name="program_id"/>
                                        <field name="name"/>
                                        <field name="amount"/>
                                        <field name="note" optional="show"/>
                                        <button name="action_open_planner"
                                                type="object"
                                                string="Planner"
                                                class="btn-link"/>
                                    </list>
                                </field>
                                <separator string="Iné"/>
                                <field name="budget_other_line_ids">
                                    <list string="Iné položky" create="0" edit="0">
                                        <field name="year" options="{'enable_formatting': False}"/>
                                        <field name="program_id"/>
                                        <field name="name"/>
                                        <field name="amount"/>
                                        <field name="note" optional="show"/>
                                        <button name="action_open_planner"
                                                type="object"
                                                string="Planner"
                                                class="btn-link"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Riadenie">
                                <group string="Zodpovedné osoby">
                                    <group>
                                        <field name="odborny_garant_id"/>
                                        <field name="project_manager_id"/>
                                    </group>
                                </group>
                                <separator string="Priradení zamestnanci"/>
                                <div class="mb-2">
                                    <button name="action_open_assignment_wizard"
                                            type="object"
                                            string="Pridať priradenie"
                                            class="btn btn-primary"
                                            invisible="not id"/>
                                </div>
                                <field name="assignment_ids" nolabel="1">
                                    <list string="Priradenia zamestnancov"
                                          create="false"
                                          delete="false"
                                          edit="false"
                                          decoration-success="state == 'active'"
                                          decoration-warning="state == 'planned'"
                                          decoration-muted="state == 'finished'">
                                        <field name="employee_id" optional="show"/>
                                        <field name="program_id" optional="show"/>
                                        <field name="date_start" optional="show"/>
                                        <field name="date_end" optional="show"/>
                                        <field name="allocation_ratio" optional="show"/>
                                        <field name="settlement_only" optional="show"/>
                                        <field name="wage_hm" optional="hide"/>
                                        <field name="wage_ccp" optional="hide" readonly="1"/>
                                        <field name="state" widget="badge"
                                               decoration-success="state == 'active'"
                                               decoration-warning="state == 'planned'"
                                               decoration-secondary="state == 'finished'"/>
                                        <field name="active" optional="hide"/>
                                        <button name="action_open_timesheet_matrix_current_year"
                                                type="object"
                                                string="Matica"
                                                icon="fa-table"
                                                class="btn-link"/>
                                        <button name="action_open_remove_wizard"
                                                type="object"
                                                string="Odstrániť"
                                                icon="fa-trash"
                                                class="btn-link text-danger"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Pôsobiská">
                                <div class="mb-2">
                                    <button name="action_open_site_wizard"
                                            type="object"
                                            string="Pridať prevádzku, centrum alebo terén"
                                            class="btn btn-primary"
                                            invisible="not id"/>
                                </div>
                                <field name="site_ids" nolabel="1">
                                    <list string="Prevádzky / centrá / terén"
                                          create="false"
                                          delete="false"
                                          edit="false">
                                        <field name="name"/>
                                        <field name="site_type"/>
                                        <field name="responsible_employee_id" optional="show"/>
                                        <field name="contact_summary" optional="show"/>
                                        <field name="address_display" optional="show"/>
                                        <field name="landlord_partner_id" optional="show"/>
                                        <button name="action_unlink_from_project"
                                                type="object"
                                                string="Odpojiť"
                                                icon="fa-chain-broken"
                                                class="btn-link"
                                                context="{'unlink_project_id': parent.id}"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Pravidlá">
                                <group string="Mzdový strop pre priradenia zamestnanca">
                                    <group>
                                        <field name="default_max_monthly_wage_hm"/>
                                        <field name="default_max_monthly_wage_ccp" readonly="1"/>
                                    </group>
                                </group>
                                <field name="leave_rule_ids">
                                    <list string="Pravidlá dovolenky" editable="bottom">
                                        <field name="leave_type_id"/>
                                        <field name="included"/>
                                        <field name="max_leaves_per_year_days"/>
                                    </list>
                                </field>
                                <separator string="Povolené typy výdavkov"/>
                                <div class="mb-2">
                                    <button name="action_open_allowed_expense_type_wizard"
                                            type="object"
                                            string="Pridať typ výdavku"
                                            class="btn btn-secondary"
                                            invisible="not id"/>
                                </div>
                                <field name="allowed_expense_type_ids" nolabel="1">
                                    <list string="Povolené typy výdavkov" editable="bottom">
                                        <field name="config_id" optional="show"/>
                                        <field name="name"/>
                                        <field name="description"/>
                                        <field name="currency_id" column_invisible="1"/>
                                        <field name="max_amount" optional="show"/>
                                        <field name="total_project_spent" optional="show"/>
                                        <field name="remaining" optional="show"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Výdavky projektu">
                                <field name="expense_ids" nolabel="1" readonly="1">
                                    <list string="Výdavky projektu" create="0" delete="0" edit="0">
                                        <field name="date"/>
                                        <field name="expense_type_config_id" optional="show"/>
                                        <field name="allowed_type_id"
                                               domain="[('project_id', '=', parent.id)]"/>
                                        <field name="description"/>
                                        <field name="currency_id" column_invisible="1"/>
                                        <field name="amount"/>
                                        <field name="charged_to"/>
                                        <field name="note" optional="hide"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Kontakty">
                                <div class="mb-2">
                                    <button name="action_open_contact_wizard"
                                            type="object"
                                            string="Pridať existujúci kontakt"
                                            class="btn btn-primary"
                                            invisible="not id"/>
                                </div>
                                <field name="contact_ids" nolabel="1">
                                    <list string="Kontakty projektu"
                                          create="true"
                                          delete="false"
                                          edit="true">
                                        <field name="name"/>
                                        <field name="email" optional="show"/>
                                        <field name="phone" optional="show"/>
                                        <field name="website" optional="show"/>
                                        <field name="note" optional="show"/>
                                        <field name="active" optional="show"/>
                                        <button name="action_unlink_from_project"
                                                type="object"
                                                string="Odpojiť"
                                                icon="fa-chain-broken"
                                                class="btn-link"
                                                context="{'unlink_project_id': parent.id}"/>
                                    </list>
                                    <form string="Kontakt projektu">
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="name"/>
                                                    <field name="active"/>
                                                </group>
                                                <group>
                                                    <field name="email"/>
                                                    <field name="phone"/>
                                                    <field name="website"/>
                                                </group>
                                            </group>
                                            <group string="Poznámka">
                                                <field name="note"/>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                                <group string="Ostatné kontaktné údaje">
                                    <field name="portal"/>
                                    <field name="donor_contact" readonly="1"/>
                                    <field name="partner_contact" readonly="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_tenenet_project_search" model="ir.ui.view">
            <field name="name">tenenet.project.search</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                    <search string="Projekty">
                        <field name="name"/>
                        <field name="ui_program_ids"/>
                        <field name="donor_id"/>
                    <filter string="Aktívne" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Bez virtuálneho admin projektu" name="hide_internal" domain="[('is_tenenet_internal', '=', False)]"/>
                    <filter string="Medzinárodné" name="international" domain="[('donor_id.donor_type', 'in', ['international', 'eu'])]"/>
                    <filter string="Donor" name="group_donor" context="{'group_by': 'donor_id'}"/>
                </search>
            </field>
        </record>

        <record id="view_tenenet_project_kanban" model="ir.ui.view">
            <field name="name">tenenet.project.kanban</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <kanban default_order="name" color="kanban_color">
                    <field name="kanban_color"/>
                    <field name="semaphore"/>
                    <field name="odborny_garant_id"/>
                    <field name="project_manager_id"/>
                    <field name="budget_total"/>
                    <field name="currency_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <templates>
                        <t t-name="card">
                            <div class="o_tenenet_project_kanban_header d-flex align-items-start justify-content-between gap-2 mb-2">
                                <strong class="d-block flex-grow-1 min-w-0">
                                    <field name="name"/>
                                </strong>
                                <span t-if="record.semaphore.raw_value == 'green'"
                                      class="o_tenenet_project_kanban_semaphore is-green flex-shrink-0"
                                      title="Zelená"/>
                                <span t-elif="record.semaphore.raw_value == 'orange'"
                                      class="o_tenenet_project_kanban_semaphore is-orange flex-shrink-0"
                                      title="Oranžová"/>
                                <span t-elif="record.semaphore.raw_value == 'red'"
                                      class="o_tenenet_project_kanban_semaphore is-red flex-shrink-0"
                                      title="Červená"/>
                            </div>
                            <div class="small text-muted">
                                <span>Garant: </span><field name="odborny_garant_id"/>
                            </div>
                            <div class="small text-muted mb-2">
                                <span>PM: </span><field name="project_manager_id"/>
                            </div>
                            <div class="d-flex justify-content-between small">
                                <field name="budget_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <span>
                                    <t t-out="record.date_start.value"/> – <t t-out="record.date_end.value"/>
                                </span>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_tenenet_project" model="ir.actions.act_window">
            <field name="name">Projekty</field>
            <field name="res_model">tenenet.project</field>
            <field name="domain">[('is_tenenet_internal', '=', False)]</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'sequence': 1, 'view_mode': 'kanban', 'view_id': ref('view_tenenet_project_kanban')}),
                (0, 0, {'sequence': 2, 'view_mode': 'list',   'view_id': ref('view_tenenet_project_list')}),
                (0, 0, {'sequence': 3, 'view_mode': 'form',   'view_id': ref('view_tenenet_project_form')}),
            ]"/>
        </record>

        <record id="view_tenenet_project_garant_kanban" model="ir.ui.view">
            <field name="name">tenenet.project.garant.kanban</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <kanban default_order="name" color="kanban_color">
                    <field name="kanban_color"/>
                    <field name="semaphore"/>
                    <field name="odborny_garant_id"/>
                    <field name="project_manager_id"/>
                    <field name="budget_total"/>
                    <field name="currency_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <templates>
                        <t t-name="card">
                            <button type="object"
                                    name="action_open_assignments_kanban"
                                    class="d-block w-100 text-start border-0 bg-transparent p-0">
                                <div class="o_tenenet_project_kanban_header d-flex align-items-start justify-content-between gap-2 mb-2">
                                    <strong class="d-block flex-grow-1 min-w-0">
                                        <field name="name"/>
                                    </strong>
                                    <span t-if="record.semaphore.raw_value == 'green'"
                                          class="o_tenenet_project_kanban_semaphore is-green flex-shrink-0"
                                          title="Zelená"/>
                                    <span t-elif="record.semaphore.raw_value == 'orange'"
                                          class="o_tenenet_project_kanban_semaphore is-orange flex-shrink-0"
                                          title="Oranžová"/>
                                    <span t-elif="record.semaphore.raw_value == 'red'"
                                          class="o_tenenet_project_kanban_semaphore is-red flex-shrink-0"
                                          title="Červená"/>
                                </div>
                                <div class="small text-muted">
                                    <span>Garant: </span><field name="odborny_garant_id"/>
                                </div>
                                <div class="small text-muted mb-2">
                                    <span>PM: </span><field name="project_manager_id"/>
                                </div>
                                <div class="d-flex justify-content-between small">
                                    <field name="budget_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <span>
                                        <t t-out="record.date_start.value"/> – <t t-out="record.date_end.value"/>
                                    </span>
                                </div>
                            </button>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_tenenet_garant_projects_server" model="ir.actions.server">
            <field name="name">Moje projekty (Garant/PM)</field>
            <field name="model_id" ref="model_tenenet_project"/>
            <field name="state">code</field>
            <field name="code">action = model.action_open_garant_projects()</field>
        </record>
    </data>
</odoo>
