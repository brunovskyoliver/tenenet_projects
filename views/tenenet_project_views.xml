<odoo>
    <data>
        <record id="view_tenenet_project_list" model="ir.ui.view">
            <field name="name">tenenet.project.list</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <list string="Projekty">
                    <field name="year"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="program_id"/>
                    <field name="donor_id"/>
                    <field name="budget_total"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_project_form" model="ir.ui.view">
            <field name="name">tenenet.project.form</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <form string="Projekt">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="year"/>
                                <field name="active"/>
                                <field name="semaphore"/>
                            </group>
                            <group>
                                <field name="program_id"/>
                                <field name="donor_id"/>
                                <field name="recipient"/>
                                <field name="contract_number"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Termíny">
                                <group>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                </group>
                            </page>
                            <page string="Riadenie">
                                <group>
                                    <field name="program_director_id"/>
                                    <field name="project_manager_id"/>
                                    <field name="financial_manager_id"/>
                                </group>
                            </page>
                            <page string="Financie">
                                <group>
                                    <field name="currency_id"/>
                                    <field name="budget_total"/>
                                    <field name="amount_contracted"/>
                                    <field name="received_2025"/>
                                    <field name="received_2026"/>
                                    <field name="received_total" readonly="1"/>
                                    <field name="budget_diff" readonly="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_project_search" model="ir.ui.view">
            <field name="name">tenenet.project.search</field>
            <field name="model">tenenet.project</field>
            <field name="arch" type="xml">
                <search string="Projekty">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="program_id"/>
                    <field name="donor_id"/>
                    <filter string="Aktívne" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Program" name="group_program" context="{'group_by': 'program_id'}"/>
                    <filter string="Rok" name="group_year" context="{'group_by': 'year'}"/>
                    <filter string="Donor" name="group_donor" context="{'group_by': 'donor_id'}"/>
                </search>
            </field>
        </record>

        <record id="action_tenenet_project" model="ir.actions.act_window">
            <field name="name">Projekty</field>
            <field name="res_model">tenenet.project</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
