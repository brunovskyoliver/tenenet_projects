<odoo>
    <data>
        <record id="view_tenenet_project_timesheet_matrix_wizard_form" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.matrix.wizard.form</field>
            <field name="model">tenenet.project.timesheet.matrix.wizard</field>
            <field name="arch" type="xml">
                <form string="Mesačná matica timesheetu">
                    <sheet>
                        <group>
                            <group>
                                <field name="project_id" options="{'no_create': True}"/>
                                <field name="year"/>
                            </group>
                        </group>
                        <field name="line_ids">
                            <list string="Mesačná matica" editable="bottom" create="0" delete="0">
                                <field name="employee_id" readonly="1"/>
                                <field name="scope" readonly="1" optional="show"/>
                                <field name="name" readonly="1"/>
                                <field name="month_01"/>
                                <field name="month_02"/>
                                <field name="month_03"/>
                                <field name="month_04"/>
                                <field name="month_05"/>
                                <field name="month_06"/>
                                <field name="month_07"/>
                                <field name="month_08"/>
                                <field name="month_09"/>
                                <field name="month_10"/>
                                <field name="month_11"/>
                                <field name="month_12"/>
                                <field name="assignment_id" column_invisible="1"/>
                                <field name="hour_type" column_invisible="1"/>
                                <field name="sequence" column_invisible="1"/>
                            </list>
                        </field>
                    </sheet>
                    <footer>
                        <button name="action_apply" type="object" string="Uložiť" class="btn-primary"/>
                        <button string="Zrušiť" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_tenenet_project_timesheet_matrix_wizard" model="ir.actions.act_window">
            <field name="name">Mesačná matica hodín</field>
            <field name="res_model">tenenet.project.timesheet.matrix.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">current</field>
        </record>
    </data>
</odoo>
