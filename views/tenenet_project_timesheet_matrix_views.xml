<odoo>
    <data>
        <record id="view_tenenet_project_timesheet_matrix_list" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.matrix.list</field>
            <field name="model">tenenet.project.timesheet.matrix</field>
            <field name="arch" type="xml">
                <list string="Mesačné matice hodín" create="0" delete="0">
                    <field name="employee_id"/>
                    <field name="project_id"/>
                    <field name="year"/>
                    <field name="assignment_id" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_matrix_form" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.matrix.form</field>
            <field name="model">tenenet.project.timesheet.matrix</field>
            <field name="arch" type="xml">
                <form string="Mesačná matica timesheetu" class="o_form_fullwidth">
                    <sheet>
                        <group>
                            <group>
                                <field name="employee_id" readonly="1"/>
                                <field name="project_id" readonly="1"/>
                                <field name="assignment_id" readonly="1"/>
                                <field name="year"/>
                            </group>
                        </group>
                        <field name="line_ids">
                            <list string="Mesačná matica" editable="bottom" create="0" delete="0">
                                <field name="employee_id" readonly="1"/>
                                <field name="scope" readonly="1" optional="show"/>
                                <field name="name" readonly="1"/>
                                <field name="month_01"/>
                                <field name="month_02"/>
                                <field name="month_03"/>
                                <field name="month_04"/>
                                <field name="month_05"/>
                                <field name="month_06"/>
                                <field name="month_07"/>
                                <field name="month_08"/>
                                <field name="month_09"/>
                                <field name="month_10"/>
                                <field name="month_11"/>
                                <field name="month_12"/>
                                <field name="assignment_id" column_invisible="1"/>
                                <field name="hour_type" column_invisible="1"/>
                                <field name="sequence" column_invisible="1"/>
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_matrix_search" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.matrix.search</field>
            <field name="model">tenenet.project.timesheet.matrix</field>
            <field name="arch" type="xml">
                <search string="Mesačné matice hodín">
                    <field name="employee_id"/>
                    <field name="project_id"/>
                    <field name="year"/>
                    <filter string="Projekt" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Zamestnanec" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Rok" name="group_year" context="{'group_by': 'year'}"/>
                </search>
            </field>
        </record>

        <record id="action_tenenet_project_timesheet_matrix" model="ir.actions.act_window">
            <field name="name">Mesačná matica hodín</field>
            <field name="res_model">tenenet.project.timesheet.matrix</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_tenenet_project_timesheet_matrix_search"/>
            <field name="target">current</field>
        </record>
    </data>
</odoo>
