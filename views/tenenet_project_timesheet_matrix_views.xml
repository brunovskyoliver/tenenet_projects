<odoo>
    <data>
        <record id="view_tenenet_project_timesheet_matrix_list" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.matrix.list</field>
            <field name="model">tenenet.project.timesheet.matrix</field>
            <field name="arch" type="xml">
                <list string="Mesačné matice hodín" create="0" delete="0">
                    <field name="employee_id"/>
                    <field name="project_id"/>
                    <field name="year"/>
                    <field name="assignment_id" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_matrix_my_list" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.matrix.my.list</field>
            <field name="model">tenenet.project.timesheet.matrix</field>
            <field name="arch" type="xml">
                <list string="Moje timesheety" create="0" delete="0">
                    <field name="project_id"/>
                    <field name="year"/>
                    <button name="action_open_form"
                            type="object"
                            string="Otvoriť maticu"
                            class="btn-link"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_matrix_form" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.matrix.form</field>
            <field name="model">tenenet.project.timesheet.matrix</field>
            <field name="arch" type="xml">
                <form string="Mesačná matica timesheetu" class="o_form_fullwidth">
                    <sheet>
                        <div class="o_tenenet_timesheet_matrix_view">
                            <div class="o_tenenet_matrix_toolbar">
                                <div class="o_tenenet_matrix_meta">
                                    <span class="o_tenenet_matrix_label">Zamestnanec</span>
                                    <field name="employee_id" readonly="1" nolabel="1"/>
                                </div>
                                <div class="o_tenenet_matrix_meta">
                                    <span class="o_tenenet_matrix_label">Projekt</span>
                                    <field name="project_id" readonly="1" nolabel="1"/>
                                </div>
                                <div class="o_tenenet_matrix_meta">
                                    <span class="o_tenenet_matrix_label">Priradenie</span>
                                    <field name="assignment_id" readonly="1" nolabel="1"/>
                                </div>
                                <!-- Year navigation with arrow buttons -->
                                <div class="o_tenenet_matrix_year_nav">
                                    <field name="can_go_previous" invisible="1"/>
                                    <field name="can_go_next" invisible="1"/>
                                    <field name="previous_year" invisible="1"/>
                                    <field name="next_year" invisible="1"/>
                                    <button name="action_previous_year"
                                            type="object"
                                            icon="fa-chevron-left"
                                            class="btn btn-secondary o_tenenet_year_nav_btn"
                                            invisible="not can_go_previous"
                                            title="Predchádzajúci rok"/>
                                    <span class="o_tenenet_year_display">
                                        <field name="year" readonly="1" nolabel="1"/>
                                    </span>
                                    <button name="action_next_year"
                                            type="object"
                                            icon="fa-chevron-right"
                                            class="btn btn-secondary o_tenenet_year_nav_btn"
                                            invisible="not can_go_next"
                                            title="Nasledujúci rok"/>
                                </div>
                            </div>
                            <field name="line_ids" nolabel="1">
                                <list string="Mesačná matica"
                                      class="o_tenenet_matrix_table"
                                      editable="bottom"
                                      create="0"
                                      delete="0">
                                    <field name="name" readonly="1" class="fw-bold" decoration-info="is_total"/>
                                    <field name="month_01" readonly="not month_01_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_02" readonly="not month_02_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_03" readonly="not month_03_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_04" readonly="not month_04_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_05" readonly="not month_05_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_06" readonly="not month_06_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_07" readonly="not month_07_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_08" readonly="not month_08_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_09" readonly="not month_09_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_10" readonly="not month_10_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_11" readonly="not month_11_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="month_12" readonly="not month_12_editable or leave_sync_managed" decoration-info="is_total"/>
                                    <field name="is_total" column_invisible="1"/>
                                    <field name="assignment_id" column_invisible="1"/>
                                    <field name="employee_id" column_invisible="1"/>
                                    <field name="hour_type" column_invisible="1"/>
                                    <field name="sequence" column_invisible="1"/>
                                    <field name="leave_sync_managed" column_invisible="1"/>
                                    <field name="month_01_editable" column_invisible="1"/>
                                    <field name="month_02_editable" column_invisible="1"/>
                                    <field name="month_03_editable" column_invisible="1"/>
                                    <field name="month_04_editable" column_invisible="1"/>
                                    <field name="month_05_editable" column_invisible="1"/>
                                    <field name="month_06_editable" column_invisible="1"/>
                                    <field name="month_07_editable" column_invisible="1"/>
                                    <field name="month_08_editable" column_invisible="1"/>
                                    <field name="month_09_editable" column_invisible="1"/>
                                    <field name="month_10_editable" column_invisible="1"/>
                                    <field name="month_11_editable" column_invisible="1"/>
                                    <field name="month_12_editable" column_invisible="1"/>
                                </list>
                            </field>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_project_timesheet_matrix_search" model="ir.ui.view">
            <field name="name">tenenet.project.timesheet.matrix.search</field>
            <field name="model">tenenet.project.timesheet.matrix</field>
            <field name="arch" type="xml">
                <search string="Mesačné matice hodín">
                    <field name="employee_id"/>
                    <field name="project_id"/>
                    <field name="year"/>
                    <filter string="Aktuálny rok" name="current_year"
                            domain="[('year', '=', context_today().year)]"/>
                    <separator/>
                    <filter string="Projekt" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Zamestnanec" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Rok" name="group_year" context="{'group_by': 'year'}"/>
                </search>
            </field>
        </record>

        <record id="action_tenenet_project_timesheet_matrix" model="ir.actions.act_window">
            <field name="name">Mesačná matica hodín</field>
            <field name="res_model">tenenet.project.timesheet.matrix</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_tenenet_project_timesheet_matrix_search"/>
            <field name="target">current</field>
        </record>

        <record id="action_tenenet_my_timesheet_matrices" model="ir.actions.server">
            <field name="name">Moje timesheety (list)</field>
            <field name="model_id" ref="model_tenenet_project_timesheet_matrix"/>
            <field name="state">code</field>
            <field name="code">action = model.action_open_my_matrices()</field>
        </record>

        <record id="action_tenenet_my_timesheets_client" model="ir.actions.client">
            <field name="name">Moje timesheety</field>
            <field name="tag">tenenet_my_timesheets</field>
            <field name="path">tenenet-my-timesheets</field>
        </record>

        <record id="action_tenenet_garant_timesheets_client" model="ir.actions.client">
            <field name="name">Garant: Timesheety A</field>
            <field name="tag">tenenet_garant_timesheets</field>
            <field name="path">tenenet-garant-timesheets</field>
        </record>
    </data>
</odoo>
