<odoo>
    <data>
        <record id="view_tenenet_project_budget_line_planner_form" model="ir.ui.view">
            <field name="name">tenenet.project.budget.line.planner.form</field>
            <field name="model">tenenet.project.budget.line</field>
            <field name="arch" type="xml">
                <form string="P&amp;L planner"
                      class="o_tenenet_budget_line_planner_form"
                      edit="0"
                      create="0"
                      delete="0">
                    <sheet class="o_tenenet_budget_line_planner_form_sheet">
                        <group>
                            <group>
                                <field name="project_id" readonly="1"/>
                                <field name="year" readonly="1" options="{'enable_formatting': False}"/>
                                <field name="budget_type" readonly="1"/>
                                <field name="program_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="detail_label" readonly="1"/>
                                <field name="expense_type_config_id" readonly="1" invisible="not expense_type_config_id"/>
                                <field name="service_income_type" readonly="1" invisible="not service_income_type"/>
                                <field name="can_cover_payroll" readonly="1" invisible="not service_income_type"/>
                                <field name="amount" readonly="1"/>
                                <field name="has_explicit_month_plan" readonly="1"/>
                            </group>
                        </group>
                        <field name="note" readonly="1" invisible="not note"/>
                        <field name="planner_state"
                               widget="tenenet_budget_line_planner"
                               nolabel="1"
                               readonly="1"/>
                    </sheet>
                    <footer>
                        <button string="Zavrieť" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
