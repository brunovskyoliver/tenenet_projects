<odoo>
    <data>
        <record id="view_tenenet_fundraising_campaign_list" model="ir.ui.view">
            <field name="name">tenenet.fundraising.campaign.list</field>
            <field name="model">tenenet.fundraising.campaign</field>
            <field name="arch" type="xml">
                <list string="Fundraisingové zbierky">
                    <field name="name"/>
                    <field name="program_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="target_amount"/>
                    <field name="raised_amount"/>
                    <field name="success_ratio"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_fundraising_campaign_form" model="ir.ui.view">
            <field name="name">tenenet.fundraising.campaign.form</field>
            <field name="model">tenenet.fundraising.campaign</field>
            <field name="arch" type="xml">
                <form string="Fundraisingová zbierka">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="program_id"/>
                                <field name="active"/>
                                <field name="target_amount"/>
                            </group>
                            <group>
                                <field name="date_start"/>
                                <field name="date_end"/>
                                <field name="raised_amount" readonly="1"/>
                                <field name="success_ratio" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="note"/>
                        </group>
                        <field name="entry_ids">
                            <list editable="bottom" string="Príspevky">
                                <field name="date_received"/>
                                <field name="amount"/>
                                <field name="source_ref"/>
                                <field name="note"/>
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_fundraising_campaign_search" model="ir.ui.view">
            <field name="name">tenenet.fundraising.campaign.search</field>
            <field name="model">tenenet.fundraising.campaign</field>
            <field name="arch" type="xml">
                <search string="Fundraisingové zbierky">
                    <field name="name"/>
                    <field name="program_id"/>
                    <filter string="Aktívne" name="active" domain="[('active', '=', True)]"/>
                </search>
            </field>
        </record>

        <record id="action_tenenet_fundraising_campaign" model="ir.actions.act_window">
            <field name="name">Fundraisingové zbierky</field>
            <field name="res_model">tenenet.fundraising.campaign</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_tenenet_fundraising_campaign_search"/>
        </record>
    </data>
</odoo>
