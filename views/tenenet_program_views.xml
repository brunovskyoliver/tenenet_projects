<odoo>
    <data>
        <record id="view_tenenet_program_list" model="ir.ui.view">
            <field name="name">tenenet.program.list</field>
            <field name="model">tenenet.program</field>
            <field name="arch" type="xml">
                <list string="Programy">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="organizational_unit_id" optional="show"/>
                    <field name="program_kind"/>
                    <field name="headcount"/>
                    <field name="dashboard_active_project_count"/>
                    <field name="dashboard_previous_month_wage_total"/>
                    <field name="reporting_fte"/>
                    <field name="operating_allocation_pct"/>
                    <field name="allocation_pct_percentage"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_program_form" model="ir.ui.view">
            <field name="name">tenenet.program.form</field>
            <field name="model">tenenet.program</field>
            <field name="arch" type="xml">
                <form string="Program" class="o_tenenet_program_form">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="organizational_unit_id"/>
                                <field name="program_kind"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="headcount" readonly="1"/>
                                <field name="reporting_fte" readonly="1"/>
                                <field name="operating_allocation_pct" readonly="1"/>
                                <field name="allocation_pct_percentage" readonly="1"/>
                            </group>
                        </group>
                        <div class="o_tenenet_program_dashboard_cards">
                            <div class="o_tenenet_program_dashboard_card">
                                <span>Aktívne projekty</span>
                                <field name="dashboard_active_project_count" readonly="1" nolabel="1"/>
                            </div>
                            <div class="o_tenenet_program_dashboard_card">
                                <span>Plán rozpočtu za rok</span>
                                <field name="dashboard_current_year_budget_total" readonly="1" nolabel="1"/>
                            </div>
                            <div class="o_tenenet_program_dashboard_card">
                                <span>Mzdy za minulý mesiac</span>
                                <field name="dashboard_previous_month_wage_total" readonly="1" nolabel="1"/>
                            </div>
                            <div class="o_tenenet_program_dashboard_card">
                                <span>Aktívne FTE</span>
                                <field name="dashboard_active_fte" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                        <group>
                            <field name="description"/>
                        </group>
                        <separator string="Projekty a tím"/>
                        <field name="dashboard_html" widget="html" readonly="1" nolabel="1"/>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_program_search" model="ir.ui.view">
            <field name="name">tenenet.program.search</field>
            <field name="model">tenenet.program</field>
            <field name="arch" type="xml">
                <search string="Programy">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="organizational_unit_id"/>
                    <filter string="Aktívne" name="active" domain="[('active', '=', True)]"/>
                </search>
            </field>
        </record>

        <record id="action_tenenet_program" model="ir.actions.act_window">
            <field name="name">Programy</field>
            <field name="res_model">tenenet.program</field>
            <field name="view_mode">list,form</field>
            <field name="domain">['&amp;', ('is_tenenet_internal', '=', False), ('code', '!=', 'ADMIN_TENENET')]</field>
        </record>
    </data>
</odoo>
