<odoo>
    <data>
        <record id="view_tenenet_organizational_unit_list" model="ir.ui.view">
            <field name="name">tenenet.organizational.unit.list</field>
            <field name="model">tenenet.organizational.unit</field>
            <field name="arch" type="xml">
                <list string="Organizačné zložky">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_tenenet_organizational_unit_form" model="ir.ui.view">
            <field name="name">tenenet.organizational.unit.form</field>
            <field name="model">tenenet.organizational.unit</field>
            <field name="arch" type="xml">
                <form string="Organizačná zložka">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tenenet_organizational_unit_search" model="ir.ui.view">
            <field name="name">tenenet.organizational.unit.search</field>
            <field name="model">tenenet.organizational.unit</field>
            <field name="arch" type="xml">
                <search string="Organizačné zložky">
                    <field name="name"/>
                    <field name="code"/>
                    <filter string="Aktívne" name="active" domain="[('active', '=', True)]"/>
                </search>
            </field>
        </record>

        <record id="action_tenenet_organizational_unit" model="ir.actions.act_window">
            <field name="name">Organizačné zložky</field>
            <field name="res_model">tenenet.organizational.unit</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
