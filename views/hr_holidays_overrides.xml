<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Change 2a: Override placeholder on description field in leave request form -->
    <record id="view_hr_leave_form_tenenet" model="ir.ui.view">
        <field name="name">hr.leave.view.form.tenenet</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name'][@widget='text']" position="attributes">
                <attribute name="placeholder">Popis (nepovinné)</attribute>
            </xpath>
        </field>
    </record>
</odoo>
