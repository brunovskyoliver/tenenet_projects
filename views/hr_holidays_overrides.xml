<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_holidays.menu_hr_holidays_root" model="ir.ui.menu">
        <field name="name">Dochádzka</field>
    </record>

    <!-- Change 2a: Override placeholder on description field in leave request form -->
    <record id="view_hr_leave_form_tenenet" model="ir.ui.view">
        <field name="name">hr.leave.view.form.tenenet</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name'][@widget='text']" position="attributes">
                <attribute name="placeholder">Popis (nepovinné)</attribute>
            </xpath>
            <!-- TENENET manager override: manually set project or force internal expense -->
            <xpath expr="//sheet" position="inside">
                <group groups="tenenet_projects.group_tenenet_manager"
                       invisible="not id">
                    <field name="tenenet_override_is_internal" string="Interné náklady"/>
                    <field name="tenenet_override_assignment_id" string="Projekt"
                           invisible="tenenet_override_is_internal"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
