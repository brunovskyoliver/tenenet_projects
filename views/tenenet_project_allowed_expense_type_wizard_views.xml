<odoo>
    <data>
        <record id="view_tenenet_project_allowed_expense_type_wizard_form" model="ir.ui.view">
            <field name="name">tenenet.project.allowed.expense.type.wizard.form</field>
            <field name="model">tenenet.project.allowed.expense.type.wizard</field>
            <field name="arch" type="xml">
                <form string="Pridať povolený typ výdavku">
                    <group>
                        <field name="project_id" invisible="1"/>
                        <field name="config_id"
                               placeholder="Vyberte z katalógu (voliteľné)…"/>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                    <footer>
                        <button name="action_add"
                                type="object"
                                string="Pridať"
                                class="btn btn-primary"/>
                        <button string="Zrušiť"
                                class="btn btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
