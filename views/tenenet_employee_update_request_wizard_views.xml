<odoo>
    <data>
        <record id="view_tenenet_employee_update_request_wizard_form" model="ir.ui.view">
            <field name="name">tenenet.employee.update.request.wizard.form</field>
            <field name="model">tenenet.employee.update.request.wizard</field>
            <field name="arch" type="xml">
                <form string="Aktualizovať kartu zamestnanca">
                    <sheet>
                        <group>
                            <field name="employee_id"/>
                            <field
                                name="request_text"
                                nolabel="1"
                                placeholder="Napíšte, čo je potrebné na karte zamestnanca aktualizovať."
                            />
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirm" string="Odoslať" type="object" class="btn-primary"/>
                        <button string="Zrušiť" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
