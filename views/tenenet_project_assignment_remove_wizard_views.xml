<odoo>
    <data>
        <record id="view_tenenet_project_assignment_remove_wizard_form" model="ir.ui.view">
            <field name="name">tenenet.project.assignment.remove.wizard.form</field>
            <field name="model">tenenet.project.assignment.remove.wizard</field>
            <field name="arch" type="xml">
                <form string="Odstrániť priradenie">
                    <sheet>
                        <group string="Priradenie">
                            <field name="project_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                        </group>
                        <div class="o_form_label">
                            Vyberte, či chcete priradenie archivovať alebo vymazať natrvalo.
                        </div>
                    </sheet>
                    <footer>
                        <button name="action_archive_assignment"
                                type="object"
                                string="Archivovať"
                                class="btn-secondary"/>
                        <button name="action_delete_assignment"
                                type="object"
                                string="Vymazať natrvalo"
                                class="btn-danger"/>
                        <button string="Zrušiť"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
