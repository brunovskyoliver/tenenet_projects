        </record>

        <record id="group_tenenet_garant_pm" model="res.groups">
            <field name="name">TENENET Odborný garant / PM (technická)</field>
            <!-- No privilege_id -> not visible in the Users UI, purely auto-managed. -->
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        </record>

        <record id="group_tenenet_helpdesk_user" model="res.groups">
            <field name="name">TENENET helpdesk používateľ</field>
