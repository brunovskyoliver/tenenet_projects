<odoo>
    <data>
        <record id="module_category_tenenet" model="ir.module.category">
            <field name="name">TENENET</field>
            <field name="description">Práva pre modul TENENET projekty</field>
            <field name="sequence">30</field>
        </record>

        <record id="privilege_tenenet_projects" model="res.groups.privilege">
            <field name="name">TENENET Projekty</field>
            <field name="category_id" ref="tenenet_projects.module_category_tenenet"/>
            <field name="sequence">10</field>
        </record>

        <record id="privilege_tenenet_helpdesk" model="res.groups.privilege">
            <field name="name">TENENET helpdesk</field>
            <field name="category_id" ref="tenenet_projects.module_category_tenenet"/>
            <field name="sequence">20</field>
        </record>

        <record id="group_tenenet_user" model="res.groups">
            <field name="name">TENENET používateľ</field>
            <field name="privilege_id" ref="tenenet_projects.privilege_tenenet_projects"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_tenenet_manager" model="res.groups">
            <field name="name">TENENET manažér</field>
            <field name="privilege_id" ref="tenenet_projects.privilege_tenenet_projects"/>
            <field name="implied_ids" eval="[(4, ref('tenenet_projects.group_tenenet_user'))]"/>
        </record>

        <record id="group_tenenet_garant_pm" model="res.groups">
            <field name="name">TENENET Odborný garant / PM (technická)</field>
            <!-- No privilege_id → not visible in the Users UI, purely auto-managed -->
            <field name="implied_ids" eval="[(4, ref('tenenet_projects.group_tenenet_user'))]"/>
        </record>

        <record id="group_tenenet_helpdesk_user" model="res.groups">
            <field name="name">TENENET helpdesk používateľ</field>
            <field name="privilege_id" ref="tenenet_projects.privilege_tenenet_helpdesk"/>
            <field name="implied_ids" eval="[(4, ref('helpdesk.group_helpdesk_user'))]"/>
        </record>

        <record id="group_tenenet_helpdesk_editor" model="res.groups">
            <field name="name">TENENET helpdesk editor</field>
            <field name="privilege_id" ref="tenenet_projects.privilege_tenenet_helpdesk"/>
            <field
                name="implied_ids"
                eval="[(4, ref('tenenet_projects.group_tenenet_helpdesk_user'))]"
            />
        </record>

        <record id="group_tenenet_helpdesk_manager" model="res.groups">
            <field name="name">TENENET helpdesk manažér</field>
            <field name="privilege_id" ref="tenenet_projects.privilege_tenenet_helpdesk"/>
            <field
                name="implied_ids"
                eval="[(4, ref('tenenet_projects.group_tenenet_helpdesk_editor'))]"
            />
        </record>
    </data>
</odoo>
