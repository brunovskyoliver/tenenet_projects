<odoo>
    <data>
        <record id="mail_template_tenenet_alert_digest" model="mail.template">
            <field name="name">TENENET upozornenie - digest</field>
            <field name="model_id" ref="model_tenenet_alert_rule"/>
            <field name="subject">[TENENET] Upozornenie: {{ object._get_digest_subject_target_text() }}</field>
            <field name="email_from">{{ user.email_formatted or '' }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Pravidlo <strong><t t-out="object.name"/></strong> našlo zhodné záznamy.</p>
                    <p>
                        Model: <t t-out="object.allowed_model_id.model_label"/><br/>
                        Čas vyhodnotenia: <t t-out="object.last_run_at or ''"/><br/>
                        Počet záznamov: <t t-out="object._get_digest_match_count()"/>
                    </p>
                    <t t-foreach="ctx.get('alert_record_rows', [])" t-as="row">
                        <div style="border: 1px solid #ddd; padding: 12px; margin: 0 0 12px 0;">
                            <p style="margin: 0 0 8px 0;">
                                <strong><t t-out="row.get('name')"/></strong>
                            </p>
                            <p t-if="row.get('project_name')" style="margin: 0 0 8px 0;">
                                <strong>Projekt:</strong> <t t-out="row.get('project_name')"/>
                            </p>
                            <div style="margin: 0 0 8px 0;">
                                <t t-foreach="row.get('match_reasons', [])" t-as="reason">
                                    <div><t t-out="reason"/></div>
                                </t>
                            </div>
                            <div style="margin: 0 0 8px 0;">
                                <t t-foreach="row.get('summary_values', [])" t-as="item">
                                    <div><strong><t t-out="item.get('label')"/>:</strong> <t t-out="item.get('value')"/></div>
                                </t>
                            </div>
                            <div><a t-att-href="row.get('url')">Otvoriť záznam</a></div>
                        </div>
                    </t>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
